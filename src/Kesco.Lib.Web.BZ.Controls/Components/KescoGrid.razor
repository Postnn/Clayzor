@typeparam TEntity where TEntity : class
@inject IDialogService DialogService
@using MudBlazor.Extensions
@using MudBlazor.Extensions.Options

<MudPaper Elevation="1" Class="pa-4">
    <div class="d-flex flex-wrap justify-space-between gap-2 mb-4" style="align-items:center">
        <MudText Typo="Typo.h5">@Title</MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField T="string"
                          Value="@_searchText"
                          ValueChanged="@OnSearchTextChanged"
                          Placeholder="Поиск..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="max-width:250px;min-width:140px" />
            @if (ShowGroupingTray)
            {
                <MudTooltip Text="@(_trayExpanded ? "Отключить группировку" : "Группировать")" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountTree"
                                   Size="Size.Small"
                                   Class="@(_trayExpanded ? "grouping-toggle-btn grouping-toggle-btn--active" : "grouping-toggle-btn")"
                                   OnClick="@ToggleTray" />
                </MudTooltip>
            }
            @if (ShowFilterTray)
            {
                <MudTooltip Text="@(_filterTrayExpanded ? "Скрыть фильтры" : "Фильтровать")" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.FilterAlt"
                                   Size="Size.Small"
                                   Class="@(_filterTrayExpanded ? "filter-toggle-btn filter-toggle-btn--active" : "filter-toggle-btn")"
                                   OnClick="@ToggleFilterTray" />
                </MudTooltip>
            }
            @if (ShowAddButton)
            {
                <MudTooltip Text="Добавить" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Class="toolbar-add-btn"
                                   OnClick="@OnAdd" />
                </MudTooltip>
            }
        </MudStack>
    </div>

    @if (ShowGroupingTray && _trayExpanded)
    {
        <div class="grouping-tray d-flex align-items-center flex-wrap gap-2 mb-2"
             @ondragover="OnTrayDragOver"
             @ondragover:preventDefault="true"
             @ondrop="@(e => OnTrayDrop(e, -1))">
            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="grouping-tray-icon" />
            @for (int i = 0; i < _groupColumns.Count; i++)
            {
                var idx = i;
                var col = _groupColumns[i];
                var displayName = AvailableGroupColumns.FirstOrDefault(kvp => kvp.Value == col).Key ?? col;
                <div class="grouping-chip"
                     draggable="true"
                     @ondragstart="@(e => OnChipDragStart(e, idx))"
                     @ondragend="OnChipDragEnd"
                     @ondragover="OnTrayDragOver"
                     @ondragover:preventDefault="true"
                     @ondrop="@(e => OnTrayDrop(e, idx))">
                    <span class="chip-label chip-label-clickable" @onclick="async () => await ToggleSort(col)" @onclick:stopPropagation="true">@displayName</span>
                    @GetSortBadge(col)
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="() => RemoveGroupColumn(col)"
                                   Class="chip-remove-btn pa-0"
                                   Style="width:18px;height:18px" />
                </div>
            }
            @if (_groupColumns.Count == 0)
            {
                <span class="grouping-tray-hint">Перетащите заголовок колонки сюда для группировки</span>
            }
        </div>
    }

    @if (ShowFilterTray && _filterTrayExpanded)
    {
        <div class="filter-tray d-flex align-items-center flex-wrap gap-2 mb-2"
             @ondragover="OnFilterTrayDragOver"
             @ondragover:preventDefault="true"
             @ondrop="OnFilterTrayDrop">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" Class="filter-tray-icon" />
            @foreach (var kv in _activeFilters)
            {
                var sqlName = kv.Key;
                var filter  = kv.Value;
                var dispName = AvailableFilterColumns.FirstOrDefault(p => p.Value == sqlName).Key ?? sqlName;
                var desc = ColumnFilterDialog.GetFilterDescription(filter, dispName);
                <div class="filter-chip">
                    <span class="chip-label chip-label-clickable"
                          @onclick="async () => await OpenFilterDialog(sqlName, dispName)"
                          @onclick:stopPropagation="true">
                        @desc
                    </span>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="async () => await RemoveFilter(sqlName)"
                                   Class="chip-remove-btn pa-0"
                                   Style="width:18px;height:18px" />
                </div>
            }
            @if (_activeFilters.Count == 0)
            {
                <span class="filter-tray-hint">Перетащите заголовок колонки сюда для фильтрации</span>
            }
        </div>
    }

    <MudDataGrid T="TEntity"
                 @key="_dataKey"
                 Items="@Items"
                 Filterable="false"
                 FixedHeader="true"
                 Height="@_gridHeight"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Loading="@Loading"
                 RowClick="@OnRowClick"
                 RowsPerPage="@_pageSize"
                 DragDropColumnReordering="@AllowColumnReorder">
        <Columns>
            @ChildContent
        </Columns>
    </MudDataGrid>
    @if (ShowPagination)
    {
        <div class="d-flex flex-wrap justify-space-between gap-2 mt-3" style="align-items:center">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText>Строк на странице:</MudText>
                <MudNumericField T="int" Value="_pageSize" ValueChanged="OnPageSizeChangedAsync" Min="1" Max="999" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:80px" />
                <MudText>Всего: @TotalCount записей</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshAsync" Size="Size.Small" title="Обновить" />
            </MudStack>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" OnClick="GoToFirstPageAsync" Disabled="@(_pageNumber <= 1)" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.NavigateBefore" OnClick="GoToPrevPageAsync" Disabled="@(_pageNumber <= 1)" Size="Size.Small" />
                <MudText Class="mx-2">Стр. @_pageNumber из @_totalPages</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.NavigateNext" OnClick="GoToNextPageAsync" Disabled="@(_pageNumber >= _totalPages)" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.LastPage" OnClick="GoToLastPageAsync" Disabled="@(_pageNumber >= _totalPages)" Size="Size.Small" />
            </MudStack>
        </div>
    }
</MudPaper>

@code {
    private string? _searchText;
    private bool _trayExpanded = false;
    private bool _filterTrayExpanded = false;
    private List<string> _groupColumns = [];
    private int _dragSourceIndex = -1;
    private List<SortColumn> _sortState = [];
    private Dictionary<string, ColumnFilter> _activeFilters = [];
    private int _pageNumber = 1;
    private int _pageSize;
    private int _dataKey;

    private string _gridHeight
    {
        get
        {
            var trays = (_trayExpanded ? 1 : 0) + (_filterTrayExpanded ? 1 : 0);
            return trays switch
            {
                2 => "calc(100vh - 380px)",
                1 => "calc(100vh - 330px)",
                _ => "calc(100vh - 280px)",
            };
        }
    }
    [Parameter] public string Title { get; set; } = "Список";
    [Parameter] public IEnumerable<TEntity> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool ShowAddButton { get; set; } = true;
    [Parameter] public int PageSize { get; set; } = 50;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnAdd { get; set; }
    [Parameter] public EventCallback<DataGridRowClickEventArgs<TEntity>> OnRowClick { get; set; }
    [Parameter] public bool ShowGroupingTray { get; set; }
    [Parameter] public Dictionary<string, string> AvailableGroupColumns { get; set; } = [];
    [Parameter] public EventCallback<KescoDataQuery> OnQueryChanged { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public bool ShowPagination { get; set; } = true;
    [Parameter] public bool AllowColumnReorder { get; set; } = true;
    /// <summary>Показывать кнопку и панель фильтрации по колонкам.</summary>
    [Parameter] public bool ShowFilterTray { get; set; }
    /// <summary>Доступные для фильтрации колонки: ключ — отображаемое имя, значение — SQL-имя.</summary>
    [Parameter] public Dictionary<string, string> AvailableFilterColumns { get; set; } = [];
    /// <summary>
    /// Тип данных для каждой фильтруемой колонки: ключ — SQL-имя, значение — <see cref="ColumnType"/>.
    /// Передаётся из <see cref="KescoGridPageBase{T}.FilterColumnTypes"/>, определяемого автоматически
    /// по C#-типам свойств сущности через рефлексию.
    /// </summary>
    [Parameter] public IReadOnlyDictionary<string, ColumnType> FilterColumnTypes { get; set; }
        = new Dictionary<string, ColumnType>();

    public IReadOnlyList<string> GroupColumns => _groupColumns.AsReadOnly();

    private int _totalPages => _pageSize > 0 && TotalCount > 0 ? (int)Math.Ceiling((double)TotalCount / _pageSize) : 1;

    protected override void OnInitialized()
    {
        _pageSize = PageSize;
    }

    protected override void OnParametersSet()
    {
        if (TotalCount > 0 && _pageNumber > _totalPages)
            _pageNumber = _totalPages;
    }

    /// <summary>
    /// Возвращает порядок группировки для указанной SQL-колонки.
    /// Используется в биндинге <c>GroupByOrder</c> на колонках грида:
    /// <c>GroupByOrder="@(_dataGrid?.GetGroupByOrder("SqlCol") ?? 0)"</c>.
    /// Меньшее значение = внешний уровень группировки.
    /// </summary>
    public int GetGroupByOrder(string sqlColumn)
    {
        var idx = _groupColumns.IndexOf(sqlColumn);
        return idx < 0 ? 0 : idx;
    }

    public async Task ToggleSort(string column)
    {
        var idx = _sortState.FindIndex(s => s.Column == column);
        if (idx >= 0)
        {
            if (_sortState[idx].Desc)
                _sortState.RemoveAt(idx);
            else
                _sortState[idx] = _sortState[idx] with { Desc = true };
        }
        else
        {
            _sortState.Insert(0, new SortColumn(column, false));
            if (_sortState.Count > 2)
                _sortState.RemoveAt(2);
        }

        _pageNumber = 1;
        await NotifyQueryChanged();
        StateHasChanged();
    }

    /// <summary>
    /// Возвращает бейдж сортировки для колонки: номер приоритета + стрелка направления.
    /// Используется как в <c>HeaderTemplate</c> колонок грида, так и в чипах панели группировки.
    /// </summary>
    public RenderFragment GetSortBadge(string column) => builder =>
    {
        var idx = _sortState.FindIndex(s => s.Column == column);
        if (idx < 0) return;
        var arrow = _sortState[idx].Desc ? "\u2193" : "\u2191";
        var label = (idx + 1).ToString() + arrow;
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "chip-sort-badge");
        builder.AddContent(2, label);
        builder.CloseElement();
    };

    private async Task ToggleTray()
    {
        _trayExpanded = !_trayExpanded;
        if (!_trayExpanded)
        {
            _groupColumns.Clear();
            _pageNumber = 1;
            await NotifyQueryChanged();
        }
        else
        {
            StateHasChanged();
        }
    }

    private async Task OnSearchTextChanged(string? value)
    {
        _searchText = value;
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task AddGroupColumn(string column)
    {
        if (_groupColumns.Contains(column))
            return;
        _groupColumns.Add(column);
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task RemoveGroupColumn(string column)
    {
        _groupColumns.Remove(column);
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private void OnChipDragStart(DragEventArgs e, int index)
    {
        e.DataTransfer.EffectAllowed = "move";
        _dragSourceIndex = index;
        // Устанавливаем KescoDragState чтобы панель фильтрации могла принять дроп
        // из чипа группировки (не только из заголовка колонки грида)
        KescoDragState.DraggedColumn = _groupColumns[index];
    }

    private void OnChipDragEnd()
    {
        _dragSourceIndex = -1;
        // Сбрасываем, если дроп не состоялся (пользователь отменил перетаскивание)
        KescoDragState.DraggedColumn = null;
    }

    private void OnTrayDragOver(DragEventArgs e)
    {
        e.DataTransfer.DropEffect = "move";
    }

    private async Task OnTrayDrop(DragEventArgs e, int targetIndex)
    {
        var draggedData = KescoDragState.DraggedColumn;
        KescoDragState.DraggedColumn = null;

        if (!string.IsNullOrEmpty(draggedData) && AvailableGroupColumns.ContainsValue(draggedData) && !_groupColumns.Contains(draggedData))
        {
            _groupColumns.Add(draggedData);
            _dragSourceIndex = -1;
            _pageNumber = 1;
            StateHasChanged();
            await NotifyQueryChanged();
            return;
        }

        if (_dragSourceIndex < 0 || _dragSourceIndex >= _groupColumns.Count)
            return;

        var item = _groupColumns[_dragSourceIndex];
        _groupColumns.RemoveAt(_dragSourceIndex);

        if (targetIndex < 0 || targetIndex >= _groupColumns.Count + 1)
            _groupColumns.Add(item);
        else if (targetIndex > _dragSourceIndex)
            _groupColumns.Insert(targetIndex - 1, item);
        else
            _groupColumns.Insert(targetIndex, item);

        _dragSourceIndex = -1;
        _pageNumber = 1;
        StateHasChanged();
        await NotifyQueryChanged();
    }

    private async Task OnPageSizeChangedAsync(int value)
    {
        _pageSize = value;
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    /// <summary>
    /// Сбрасывает номер страницы на 1 и инициирует перезагрузку данных.
    /// </summary>
    public async Task RefreshAsync()
    {
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task GoToFirstPageAsync()
    {
        if (_pageNumber <= 1) return;
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task GoToPrevPageAsync()
    {
        if (_pageNumber <= 1) return;
        _pageNumber--;
        await NotifyQueryChanged();
    }

    private async Task GoToNextPageAsync()
    {
        if (_pageNumber >= _totalPages) return;
        _pageNumber++;
        await NotifyQueryChanged();
    }

    private async Task GoToLastPageAsync()
    {
        if (_pageNumber >= _totalPages) return;
        _pageNumber = _totalPages;
        await NotifyQueryChanged();
    }

    // ── Filter tray ────────────────────────────────────────────────────────────

    /// <summary>
    /// Включает/выключает панель фильтрации.
    /// При выключении сбрасывает все активные фильтры и перезагружает данные.
    /// </summary>
    private async Task ToggleFilterTray()
    {
        _filterTrayExpanded = !_filterTrayExpanded;
        if (!_filterTrayExpanded)
        {
            _activeFilters.Clear();
            _pageNumber = 1;
            await NotifyQueryChanged();
        }
        else
        {
            StateHasChanged();
        }
    }

    private void OnFilterTrayDragOver(DragEventArgs e)
    {
        e.DataTransfer.DropEffect = "move";
    }

    private async Task OnFilterTrayDrop(DragEventArgs e)
    {
        var draggedSqlName = KescoDragState.DraggedColumn;
        KescoDragState.DraggedColumn = null;

        if (string.IsNullOrEmpty(draggedSqlName))
            return;
        if (!AvailableFilterColumns.ContainsValue(draggedSqlName))
            return;

        var displayName = AvailableFilterColumns.FirstOrDefault(p => p.Value == draggedSqlName).Key ?? draggedSqlName;
        await OpenFilterDialog(draggedSqlName, displayName);
    }

    /// <summary>
    /// Открывает диалог настройки фильтра для указанной колонки.
    /// При подтверждении сохраняет фильтр и перезагружает данные.
    /// </summary>
    private async Task OpenFilterDialog(string sqlName, string displayName)
    {
        var colType = FilterColumnTypes.TryGetValue(sqlName, out var t) ? t : ColumnType.Text;
        _activeFilters.TryGetValue(sqlName, out var existing);

        var parameters = new DialogParameters<ColumnFilterDialog>
        {
            { x => x.ColumnDisplayName, displayName },
            { x => x.ColumnSqlName,     sqlName },
            { x => x.ColumnType,        colType },
            { x => x.ExistingFilter,    existing },
        };
        var options = new DialogOptionsEx
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            DragMode = MudDialogDragMode.Simple,
        };
        var dialog = await DialogService.ShowExAsync<ColumnFilterDialog>(
            $"Фильтр: {displayName}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is ColumnFilter colFilter)
        {
            _activeFilters[sqlName] = colFilter;
            _pageNumber = 1;
            await NotifyQueryChanged();
        }
    }

    private async Task RemoveFilter(string sqlName)
    {
        _activeFilters.Remove(sqlName);
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task NotifyQueryChanged()
    {
        _dataKey++;
        var query = new KescoDataQuery
        {
            SearchText   = _searchText,
            GroupEnabled = _groupColumns.Count > 0,
            GroupColumns = _groupColumns.ToList(),
            SortColumns  = _sortState.ToList(),
            PageNumber   = _pageNumber,
            PageSize     = _pageSize,
            ColumnFilters = _activeFilters.ToDictionary(kv => kv.Key, kv => kv.Value),
        };
        await OnQueryChanged.InvokeAsync(query);
    }
}
