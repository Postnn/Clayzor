@typeparam TEntity where TEntity : class

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">@Title</MudText>
        <MudStack Row="true" Spacing="2">
            <MudTextField T="string"
                          Value="@_searchText"
                          ValueChanged="@OnSearchTextChanged"
                          Placeholder="Поиск..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
            @if (ShowAddButton)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@OnAdd">
                    Добавить
                </MudButton>
            }
        </MudStack>
    </MudStack>

    @if (ShowGroupToggle)
    {
        <MudStack Row="true" Class="mb-2">
            <MudSwitch @bind-Value="_groupEnabled"
                       @bind-Value:after="OnGroupToggleChanged"
                       Label="@GroupToggleLabel"
                       Color="Color.Primary" />
        </MudStack>
    }

    @if (ShowGroupingTray)
    {
        <div class="grouping-tray d-flex align-items-center flex-wrap gap-2 mb-2"
             @ondragover="OnTrayDragOver"
             @ondragover:preventDefault="true"
             @ondrop="@(e => OnTrayDrop(e, -1))">
            <MudText Typo="Typo.body2" Class="mr-1">Группировка:</MudText>
            @for (int i = 0; i < _groupColumns.Count; i++)
            {
                var idx = i;
                var col = _groupColumns[i];
                var displayName = AvailableGroupColumns.FirstOrDefault(kvp => kvp.Value == col).Key ?? col;
                <div class="grouping-chip"
                     draggable="true"
                     @ondragstart="@(e => OnChipDragStart(e, idx))"
                     @ondragend="OnChipDragEnd"
                     @ondragover="OnTrayDragOver"
                     @ondragover:preventDefault="true"
                     @ondrop="@(e => OnTrayDrop(e, idx))">
                    <span class="chip-label" @onclick="() => ToggleSort(col)" @onclick:stopPropagation="true">@displayName</span>
                    @GetSortBadge(col)
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="() => RemoveGroupColumn(col)"
                                   Class="chip-remove-btn pa-0"
                                   Style="width:18px;height:18px" />
                </div>
            }
            @if (_groupColumns.Count < AvailableGroupColumns.Count)
            {
                <MudMenu Variant="Variant.Outlined"
                         Size="Size.Small"
                         AnchorOrigin="Origin.BottomCenter"
                         TransformOrigin="Origin.TopCenter">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Style="text-transform:none">
                            Колонка
                        </MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        @foreach (var kvp in AvailableGroupColumns)
                        {
                            if (!_groupColumns.Contains(kvp.Value))
                            {
                                <MudMenuItem OnClick="() => AddGroupColumn(kvp.Value)">@kvp.Key</MudMenuItem>
                            }
                        }
                    </ChildContent>
                </MudMenu>
            }
        </div>
    }

    <MudDataGrid T="TEntity"
                 @ref="_mudGrid"
                 Items="@Items"
                 Filterable="false"
                 SortMode="SortMode.Multiple"
                 Groupable="@(ShowGroupingTray ? _groupColumns.Count > 0 : Groupable)"
                 GroupExpanded="@GroupExpanded"
                 FixedHeader="true"
                 Height="calc(100vh - 310px)"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Loading="@Loading"
                 RowClick="@OnRowClick"
                 RowsPerPage="@_pageSize"
                 DragDropColumnReordering="@AllowColumnReorder">
        <Columns>
            @ChildContent
        </Columns>
    </MudDataGrid>
    @if (ShowPagination)
    {
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText>Строк на странице:</MudText>
                <MudNumericField T="int" Value="_pageSize" ValueChanged="OnPageSizeChangedAsync" Min="1" Max="999" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:80px" />
                <MudText>Всего: @TotalCount записей</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshAsync" Size="Size.Small" title="Обновить" />
            </MudStack>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" OnClick="GoToFirstPageAsync" Disabled="@(_pageNumber <= 1)" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.NavigateBefore" OnClick="GoToPrevPageAsync" Disabled="@(_pageNumber <= 1)" Size="Size.Small" />
                <MudText Class="mx-2">Стр. @_pageNumber из @_totalPages</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.NavigateNext" OnClick="GoToNextPageAsync" Disabled="@(_pageNumber >= _totalPages)" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.LastPage" OnClick="GoToLastPageAsync" Disabled="@(_pageNumber >= _totalPages)" Size="Size.Small" />
            </MudStack>
        </MudStack>
    }
</MudPaper>

@code {
    private string? _searchText;
    private bool _groupEnabled;
    private List<string> _groupColumns = [];
    private int _dragSourceIndex = -1;
    private List<SortColumn> _sortState = [];
    private int _pageNumber = 1;
    private int _pageSize;
    private MudDataGrid<TEntity> _mudGrid = default!;
    [Parameter] public string Title { get; set; } = "Список";
    [Parameter] public IEnumerable<TEntity> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool ShowAddButton { get; set; } = true;
    [Parameter] public int PageSize { get; set; } = 50;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnAdd { get; set; }
    [Parameter] public EventCallback<DataGridRowClickEventArgs<TEntity>> OnRowClick { get; set; }
    [Parameter] public bool Groupable { get; set; }
    [Parameter] public bool GroupExpanded { get; set; } = true;
    [Parameter] public string? GroupColumn { get; set; }
    [Parameter] public bool ShowGroupToggle { get; set; }
    [Parameter] public string GroupToggleLabel { get; set; } = "Группировать";
    [Parameter] public bool ShowGroupingTray { get; set; }
    [Parameter] public Dictionary<string, string> AvailableGroupColumns { get; set; } = [];
    [Parameter] public EventCallback<KescoDataQuery> OnQueryChanged { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public bool ShowPagination { get; set; } = true;
    [Parameter] public bool AllowColumnReorder { get; set; } = true;

    public bool GroupEnabled => _groupEnabled;
    public IReadOnlyList<string> GroupColumns => _groupColumns.AsReadOnly();

    private int _totalPages => _pageSize > 0 && TotalCount > 0 ? (int)Math.Ceiling((double)TotalCount / _pageSize) : 1;

    protected override void OnInitialized()
    {
        _pageSize = PageSize;
    }

    protected override void OnParametersSet()
    {
        if (TotalCount > 0 && _pageNumber > _totalPages)
            _pageNumber = _totalPages;
    }

    /// <summary>
    /// Возвращает порядок группировки для указанной SQL-колонки.
    /// Используется в биндинге <c>GroupByOrder</c> на колонках грида:
    /// <c>GroupByOrder="@(_dataGrid?.GetGroupByOrder("SqlCol") ?? 0)"</c>.
    /// Меньшее значение = внешний уровень группировки.
    /// </summary>
    public int GetGroupByOrder(string sqlColumn)
    {
        var idx = _groupColumns.IndexOf(sqlColumn);
        return idx < 0 ? 0 : idx;
    }

    public void ToggleSort(string column)
    {
        var idx = _sortState.FindIndex(s => s.Column == column);
        if (idx >= 0)
        {
            if (_sortState[idx].Desc)
                _sortState.RemoveAt(idx);
            else
                _sortState[idx] = _sortState[idx] with { Desc = true };
        }
        else
        {
            _sortState.Insert(0, new SortColumn(column, false));
            if (_sortState.Count > 2)
                _sortState.RemoveAt(2);
        }

        InvokeAsync(async () =>
        {
            _pageNumber = 1;
            StateHasChanged();
            await NotifyQueryChanged();
        });
    }

    public RenderFragment GetSortBadge(string column) => builder =>
    {
        var idx = _sortState.FindIndex(s => s.Column == column);
        if (idx < 0) return;
        var arrow = _sortState[idx].Desc ? "\u2193" : "\u2191";
        var label = (idx + 1).ToString() + arrow;
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "style", "background:var(--mud-palette-primary);color:white;border-radius:6px;padding:0 4px;margin-left:4px;font-size:0.75rem;font-weight:600");
        builder.AddContent(2, label);
        builder.CloseElement();
    };

    private async Task OnSearchTextChanged(string? value)
    {
        _searchText = value;
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task OnGroupToggleChanged()
    {
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task AddGroupColumn(string column)
    {
        if (_groupColumns.Contains(column))
            return;
        _groupColumns.Add(column);
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task RemoveGroupColumn(string column)
    {
        _groupColumns.Remove(column);
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private void OnChipDragStart(DragEventArgs e, int index)
    {
        e.DataTransfer.EffectAllowed = "move";
        _dragSourceIndex = index;
    }

    private void OnChipDragEnd()
    {
        _dragSourceIndex = -1;
    }

    private void OnTrayDragOver(DragEventArgs e)
    {
        e.DataTransfer.DropEffect = "move";
    }

    private async Task OnTrayDrop(DragEventArgs e, int targetIndex)
    {
        var draggedData = KescoDragState.DraggedColumn;
        KescoDragState.DraggedColumn = null;

        if (!string.IsNullOrEmpty(draggedData) && AvailableGroupColumns.ContainsValue(draggedData) && !_groupColumns.Contains(draggedData))
        {
            _groupColumns.Add(draggedData);
            _dragSourceIndex = -1;
            _pageNumber = 1;
            StateHasChanged();
            await NotifyQueryChanged();
            return;
        }

        if (_dragSourceIndex < 0 || _dragSourceIndex >= _groupColumns.Count)
            return;

        var item = _groupColumns[_dragSourceIndex];
        _groupColumns.RemoveAt(_dragSourceIndex);

        if (targetIndex < 0 || targetIndex >= _groupColumns.Count + 1)
            _groupColumns.Add(item);
        else if (targetIndex > _dragSourceIndex)
            _groupColumns.Insert(targetIndex - 1, item);
        else
            _groupColumns.Insert(targetIndex, item);

        _dragSourceIndex = -1;
        _pageNumber = 1;
        StateHasChanged();
        await NotifyQueryChanged();
    }

    private async Task OnPageSizeChangedAsync(int value)
    {
        _pageSize = value;
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task RefreshAsync()
    {
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task GoToFirstPageAsync()
    {
        if (_pageNumber <= 1) return;
        _pageNumber = 1;
        await NotifyQueryChanged();
    }

    private async Task GoToPrevPageAsync()
    {
        if (_pageNumber <= 1) return;
        _pageNumber--;
        await NotifyQueryChanged();
    }

    private async Task GoToNextPageAsync()
    {
        if (_pageNumber >= _totalPages) return;
        _pageNumber++;
        await NotifyQueryChanged();
    }

    private async Task GoToLastPageAsync()
    {
        if (_pageNumber >= _totalPages) return;
        _pageNumber = _totalPages;
        await NotifyQueryChanged();
    }

    private async Task NotifyQueryChanged()
    {
        var query = new KescoDataQuery
        {
            SearchText = _searchText,
            GroupEnabled = ShowGroupingTray ? _groupColumns.Count > 0 : _groupEnabled,
            GroupColumns = _groupColumns.ToList(),
            SortColumns = _sortState.ToList(),
            PageNumber = _pageNumber,
            PageSize = _pageSize
        };
        await OnQueryChanged.InvokeAsync(query);
    }
}
