@using Kesco.Lib.Web.BZ.Controls
@implements IDisposable

@inject KescoErrorService ErrorService

@if (ErrorService.HasError)
{
    <div style="background:#d32f2f;color:#fff;padding:12px 16px;border-radius:4px;margin-bottom:16px">
        <div style="display:flex;justify-content:space-between;align-items:center">
            <span style="font-weight:600;word-break:break-word">@ErrorService.ErrorMessage</span>
            <span style="cursor:pointer;font-size:1.3rem;padding:0 4px" @onclick="() => Close()">&times;</span>
        </div>

        <div style="cursor:pointer;margin-top:6px;opacity:0.85;font-size:0.9rem" @onclick="() => ToggleDetails()">
            @(_showDebug ? "▲ Скрыть детали" : "▼ Детали запроса")
        </div>

        @if (_showDebug)
        {
            <div style="margin-top:8px;font-size:0.8rem;opacity:0.9">
                @if (!string.IsNullOrEmpty(ErrorService.ConnectionString))
                {
                    <div style="margin-bottom:6px"><strong>Строка подключения:</strong><br>@ErrorService.ConnectionString</div>
                }
                @if (ErrorService.CommandTexts.Count > 0)
                {
                    <div style="margin-bottom:4px"><strong>SQL:</strong></div>
                    @for (int i = 0; i < ErrorService.CommandTexts.Count; i++)
                    {
                        var label = i < ErrorService.CommandLabels.Count ? ErrorService.CommandLabels[i] : $"Запрос {i + 1}";
                        <details style="margin-bottom:4px">
                            <summary style="cursor:pointer;padding:4px 8px;background:#b71c1c;border-radius:3px">@label</summary>
                            <pre style="white-space:pre-wrap;word-break:break-all;background:#8b0000;color:#ffcdd2;padding:8px;border-radius:0 0 4px 4px;margin:0;max-height:300px;overflow:auto">@ErrorService.CommandTexts[i]</pre>
                        </details>
                    }
                }
                @if (ErrorService.Parameters.Count > 0)
                {
                    <div style="margin-top:6px;margin-bottom:4px"><strong>Параметры:</strong></div>
                    <table style="width:100%;border-collapse:collapse;background:#b71c1c;border-radius:3px;overflow:hidden">
                        <thead>
                            <tr style="background:#8b0000">
                                <th style="padding:4px 8px;text-align:left;color:#ffcdd2">Параметр</th>
                                <th style="padding:4px 8px;text-align:left;color:#ffcdd2">Значение</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in ErrorService.Parameters)
                            {
                                <tr>
                                    <td style="padding:3px 8px;color:#ffcdd2">@p.Name</td>
                                    <td style="padding:3px 8px;color:#ef9a9a"><code>@(p.Value?.ToString() ?? "NULL")</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
    </div>
}

@code {
    private bool _showDebug;

    protected override void OnInitialized()
    {
        ErrorService.OnChanged += StateHasChanged;
    }

    private void ToggleDetails()
    {
        _showDebug = !_showDebug;
        StateHasChanged();
    }

    private void Close()
    {
        _showDebug = false;
        ErrorService.Clear();
    }

    public void Dispose()
    {
        ErrorService.OnChanged -= StateHasChanged;
    }
}
