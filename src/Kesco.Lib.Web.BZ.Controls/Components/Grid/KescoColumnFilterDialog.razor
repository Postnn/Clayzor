@using MudBlazor
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="display:flex;align-items:center;gap:8px">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" />
            Фильтр: @ColumnDisplayName
        </MudText>
    </TitleContent>
    <DialogContent>
        <div @onkeydown="OnKeyDown" style="display:flex;flex-direction:column;gap:12px">
            <MudText Typo="Typo.body2">
                Показать только те строки, значения которых:
            </MudText>

            @* ── Первое условие ──────────────────────────────────── *@
            <MudSelect T="ColumnFilterOperator"
                       Label="Условие"
                       @bind-Value="_op1"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       AnchorOrigin="Origin.BottomLeft">
                @foreach (var op in _availableOperators)
                {
                    <MudSelectItem Value="@op">@GetOperatorLabel(op)</MudSelectItem>
                }
            </MudSelect>

            @if (!IsEmptyOrNotEmpty(_op1))
            {
                if (ColumnType == ColumnType.Text)
                {
                    <MudTextField T="string" Label="Значение" @bind-Value="_text1" @ref="_textFieldRef"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Clearable="true" AutoFocus="true" />
                }
                else if (ColumnType == ColumnType.Number)
                {
                    <MudNumericField T="int?" Label="Значение" @bind-Value="_num1" @ref="_numFieldRef"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" AutoFocus="true" />
                }
                else if (ColumnType == ColumnType.Boolean)
                {
                    <MudSelect T="bool?" Label="Значение" @bind-Value="_bool1" @ref="_boolFieldRef"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               AnchorOrigin="Origin.BottomLeft" Clearable="true">
                        <MudSelectItem Value="@((bool?)true)">Да</MudSelectItem>
                        <MudSelectItem Value="@((bool?)false)">Нет</MudSelectItem>
                    </MudSelect>
                }
            }

            @* ── Второе условие (опционально) ────────────────────── *@
            @if (_showSecond)
            {
                <MudDivider />

                <div class="d-flex align-items-center gap-1">
                    <MudButton Variant="@(_logic == LogicalOperator.And ? Variant.Filled : Variant.Outlined)"
                               Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="() => SetLogic(LogicalOperator.And)">И</MudButton>
                    <MudButton Variant="@(_logic == LogicalOperator.Or ? Variant.Filled : Variant.Outlined)"
                               Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="() => SetLogic(LogicalOperator.Or)">ИЛИ</MudButton>
                    <MudSpacer />
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="RemoveSecond"
                                   Style="width:28px;height:28px" />
                </div>

                <MudSelect T="ColumnFilterOperator"
                           Label="Условие"
                           @bind-Value="_op2"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           AnchorOrigin="Origin.BottomLeft">
                    @foreach (var op in _availableOperators)
                    {
                        <MudSelectItem Value="@op">@GetOperatorLabel(op)</MudSelectItem>
                    }
                </MudSelect>

                @if (!IsEmptyOrNotEmpty(_op2))
                {
                    if (ColumnType == ColumnType.Text)
                    {
                        <MudTextField T="string" Label="Значение" @bind-Value="_text2" @ref="_textFieldRef2"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Clearable="true" />
                    }
                    else if (ColumnType == ColumnType.Number)
                    {
                        <MudNumericField T="int?" Label="Значение" @bind-Value="_num2" @ref="_numFieldRef2"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                    }
                    else if (ColumnType == ColumnType.Boolean)
                    {
                        <MudSelect T="bool?" Label="Значение" @bind-Value="_bool2" @ref="_boolFieldRef2"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AnchorOrigin="Origin.BottomLeft" Clearable="true">
                            <MudSelectItem Value="@((bool?)true)">Да</MudSelectItem>
                            <MudSelectItem Value="@((bool?)false)">Нет</MudSelectItem>
                        </MudSelect>
                    }
                }
            }
            else
            {
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddSecond"
                           Style="text-transform:none;align-self:flex-start">
                    добавить условие
                </MudButton>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Apply"
                   Disabled="@(!HasValidValue)">
            Применить
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .mud-dialog-content { overflow: visible; }
    .mud-list-item { padding-block: 4px; min-height: 32px; }
    .mud-popover .mud-list { max-height: 260px; }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    /// <summary>Отображаемое имя колонки (заголовок диалога).</summary>
    [Parameter] public string ColumnDisplayName { get; set; } = "";

    /// <summary>SQL-имя колонки — включается в возвращаемый <see cref="ColumnFilter"/>.</summary>
    [Parameter] public string ColumnSqlName { get; set; } = "";

    /// <summary>Тип данных колонки — определяет доступные операторы и поле ввода.</summary>
    [Parameter] public ColumnType ColumnType { get; set; } = ColumnType.Text;

    /// <summary>Существующий фильтр для режима редактирования. null — новый фильтр.</summary>
    [Parameter] public ColumnFilter? ExistingFilter { get; set; }

    // ── Состояние первого условия ──────────────────────────────────────────────
    private ColumnFilterOperator _op1;
    private string? _text1;
    private int? _num1;
    private bool? _bool1;

    // ── Состояние второго условия ──────────────────────────────────────────────
    private bool _showSecond;
    private LogicalOperator _logic = LogicalOperator.And;
    private ColumnFilterOperator _op2;
    private string? _text2;
    private int? _num2;
    private bool? _bool2;

    private IReadOnlyList<ColumnFilterOperator> _availableOperators = [];

    private MudTextField<string>? _textFieldRef;
    private MudNumericField<int?>? _numFieldRef;
    private MudSelect<bool?>? _boolFieldRef;

    private MudTextField<string>? _textFieldRef2;
    private MudNumericField<int?>? _numFieldRef2;
    private MudSelect<bool?>? _boolFieldRef2;

    private bool _focusSecond;

    /// <summary>
    /// Устанавливает фокус на поле ввода значения: при открытии — на первое,
    /// после добавления второго условия или переключения И/ИЛИ — на второе.
    /// </summary>
    /// <summary>
    /// Устанавливает фокус на поле ввода значения второго условия после его добавления.
    /// Первое условие фокусируется нативно через <c>AutoFocus="true"</c> на полях ввода.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusSecond && _showSecond && !IsEmptyOrNotEmpty(_op2))
        {
            if (_textFieldRef2 is not null)      await _textFieldRef2.FocusAsync();
            else if (_numFieldRef2 is not null)  await _numFieldRef2.FocusAsync();
            else if (_boolFieldRef2 is not null) await _boolFieldRef2.FocusAsync();
            _focusSecond = false;
        }
    }

    /// <summary>
    /// Обрабатывает нажатие Enter — применяет фильтр если значение валидно.
    /// </summary>
    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && HasValidValue)
            Apply();
    }

    /// <summary>
    /// Возвращает читаемое описание фильтра для отображения в чипе панели фильтров.
    /// </summary>
    public static string GetFilterDescription(ColumnFilter filter, string displayName)
    {
        var first = DescribeClause(filter.Operator, filter.Value);
        if (filter.HasSecondClause)
        {
            var second = DescribeClause(filter.SecondOperator, filter.SecondValue);
            var logic = filter.LogicalOperator == LogicalOperator.Or ? "ИЛИ" : "И";
            return $"{displayName}: {first} {logic} {second}";
        }
        return $"{displayName}: {first}";
    }

    private static string DescribeClause(ColumnFilterOperator op, object? value) => op switch
    {
        ColumnFilterOperator.Contains           => $"содержит «{value}»",
        ColumnFilterOperator.NotContains        => $"не содержит «{value}»",
        ColumnFilterOperator.Equals             => $"= «{value}»",
        ColumnFilterOperator.NotEquals          => $"≠ «{value}»",
        ColumnFilterOperator.StartsWith         => $"начинается с «{value}»",
        ColumnFilterOperator.NotStartsWith      => $"не начинается с «{value}»",
        ColumnFilterOperator.EndsWith           => $"заканчивается на «{value}»",
        ColumnFilterOperator.NotEndsWith        => $"не заканчивается на «{value}»",
        ColumnFilterOperator.GreaterThan        => $"> «{value}»",
        ColumnFilterOperator.GreaterThanOrEqual => $"≥ «{value}»",
        ColumnFilterOperator.LessThan           => $"< «{value}»",
        ColumnFilterOperator.LessThanOrEqual    => $"≤ «{value}»",
        ColumnFilterOperator.IsEmpty            => "пустая строка",
        ColumnFilterOperator.IsNotEmpty         => "не пустая строка",
        _ => $"= «{value}»"
    };

    private static bool IsEmptyOrNotEmpty(ColumnFilterOperator op)
        => op is ColumnFilterOperator.IsEmpty or ColumnFilterOperator.IsNotEmpty;

    protected override void OnParametersSet()
    {
        _availableOperators = ColumnType switch
        {
            ColumnType.Text    => ColumnFilterOperatorList.TextOperators,
            ColumnType.Number  => ColumnFilterOperatorList.NumberOperators,
            ColumnType.Boolean => ColumnFilterOperatorList.BooleanOperators,
            _ => ColumnFilterOperatorList.TextOperators
        };

        if (ExistingFilter is not null)
        {
            _op1 = ExistingFilter.Operator;
            RestoreValue1(ExistingFilter.Value);

            if (ExistingFilter.HasSecondClause)
            {
                _showSecond = true;
                _logic      = ExistingFilter.LogicalOperator;
                _op2        = ExistingFilter.SecondOperator;
                RestoreValue2(ExistingFilter.SecondValue);
            }
            else
            {
                _showSecond = false;
            }
        }
        else
        {
            _op1 = _availableOperators[0];
            _showSecond = false;
        }
    }

    private void RestoreValue1(object? value)
    {
        (_text1, _num1, _bool1) = ((string?)null, (int?)null, (bool?)null);
        if (ColumnType == ColumnType.Text)      _text1 = value?.ToString();
        else if (ColumnType == ColumnType.Number) _num1 = value is int i ? i : value is not null ? (int?)Convert.ToInt32(value) : null;
        else if (ColumnType == ColumnType.Boolean) _bool1 = value is bool b ? b : null;
    }

    private void RestoreValue2(object? value)
    {
        (_text2, _num2, _bool2) = ((string?)null, (int?)null, (bool?)null);
        if (ColumnType == ColumnType.Text)      _text2 = value?.ToString();
        else if (ColumnType == ColumnType.Number) _num2 = value is int i ? i : value is not null ? (int?)Convert.ToInt32(value) : null;
        else if (ColumnType == ColumnType.Boolean) _bool2 = value is bool b ? b : null;
    }

    private object? GetValue1() => ColumnType switch
    {
        ColumnType.Text    => _text1,
        ColumnType.Number  => _num1,
        ColumnType.Boolean => (object?)_bool1,
        _ => _text1
    };

    private object? GetValue2() => ColumnType switch
    {
        ColumnType.Text    => _text2,
        ColumnType.Number  => _num2,
        ColumnType.Boolean => (object?)_bool2,
        _ => _text2
    };

    private bool Clause1HasValue => IsEmptyOrNotEmpty(_op1) || ColumnType switch
    {
        ColumnType.Text    => !string.IsNullOrEmpty(_text1),
        ColumnType.Number  => _num1.HasValue,
        ColumnType.Boolean => _bool1.HasValue,
        _ => false
    };

    private bool Clause2HasValue => IsEmptyOrNotEmpty(_op2) || ColumnType switch
    {
        ColumnType.Text    => !string.IsNullOrEmpty(_text2),
        ColumnType.Number  => _num2.HasValue,
        ColumnType.Boolean => _bool2.HasValue,
        _ => false
    };

    private bool HasValidValue => _showSecond
        ? Clause1HasValue && Clause2HasValue
        : Clause1HasValue;

    private void AddSecond()
    {
        _showSecond = true;
        _op2 = _availableOperators.Count > 0 ? _availableOperators[0] : ColumnFilterOperator.Contains;
        _focusSecond = true;
    }

    private void RemoveSecond()
    {
        _showSecond = false;
        _text2 = null;
        _num2 = null;
        _bool2 = null;
    }

    private void SetLogic(LogicalOperator op)
    {
        _logic = op;
        _focusSecond = true;
    }

    private void Cancel() => MudDialog?.Cancel();

    private void Apply()
    {
        if (!HasValidValue) return;

        var filter = new ColumnFilter
        {
            Column    = ColumnSqlName,
            ParamName = Transliterate("cf_" + ColumnSqlName),
            Operator  = _op1,
            Value     = GetValue1(),
        };

        if (_showSecond)
        {
            filter.LogicalOperator = _logic;
            filter.SecondOperator  = _op2;
            filter.SecondValue     = GetValue2();
            filter.SecondParamName = Transliterate("cf2_" + ColumnSqlName);
        }

        MudDialog?.Close(DialogResult.Ok(filter));
    }

    private static string Transliterate(string input) =>
        input.Replace(".", "_").Replace(" ", "_")
             .Replace("А","A").Replace("а","a")
             .Replace("Б","B").Replace("б","b")
             .Replace("В","V").Replace("в","v")
             .Replace("Г","G").Replace("г","g")
             .Replace("Д","D").Replace("д","d")
             .Replace("Е","E").Replace("е","e")
             .Replace("Ё","Yo").Replace("ё","yo")
             .Replace("Ж","Zh").Replace("ж","zh")
             .Replace("З","Z").Replace("з","z")
             .Replace("И","I").Replace("и","i")
             .Replace("Й","Y").Replace("й","y")
             .Replace("К","K").Replace("к","k")
             .Replace("Л","L").Replace("л","l")
             .Replace("М","M").Replace("м","m")
             .Replace("Н","N").Replace("н","n")
             .Replace("О","O").Replace("о","o")
             .Replace("П","P").Replace("п","p")
             .Replace("Р","R").Replace("р","r")
             .Replace("С","S").Replace("с","s")
             .Replace("Т","T").Replace("т","t")
             .Replace("У","U").Replace("у","u")
             .Replace("Ф","F").Replace("ф","f")
             .Replace("Х","Kh").Replace("х","kh")
             .Replace("Ц","Ts").Replace("ц","ts")
             .Replace("Ч","Ch").Replace("ч","ch")
             .Replace("Ш","Sh").Replace("ш","sh")
             .Replace("Щ","Sch").Replace("щ","sch")
             .Replace("Ъ","").Replace("ъ","")
             .Replace("Ы","Y").Replace("ы","y")
             .Replace("Ь","").Replace("ь","")
             .Replace("Э","E").Replace("э","e")
             .Replace("Ю","Yu").Replace("ю","yu")
             .Replace("Я","Ya").Replace("я","ya");

    private static string GetOperatorLabel(ColumnFilterOperator op) => op switch
    {
        ColumnFilterOperator.Contains           => "содержит",
        ColumnFilterOperator.NotContains        => "не содержит",
        ColumnFilterOperator.Equals             => "равно",
        ColumnFilterOperator.NotEquals          => "не равно",
        ColumnFilterOperator.StartsWith         => "начинается с",
        ColumnFilterOperator.NotStartsWith      => "не начинается с",
        ColumnFilterOperator.EndsWith           => "заканчивается на",
        ColumnFilterOperator.NotEndsWith        => "не заканчивается на",
        ColumnFilterOperator.GreaterThan        => "больше (>)",
        ColumnFilterOperator.GreaterThanOrEqual => "больше или равно (≥)",
        ColumnFilterOperator.LessThan           => "меньше (<)",
        ColumnFilterOperator.LessThanOrEqual    => "меньше или равно (≤)",
        ColumnFilterOperator.IsEmpty            => "пустая строка",
        ColumnFilterOperator.IsNotEmpty         => "не пустая строка",
        _ => op.ToString()
    };
}