@typeparam TEntity where TEntity : class
@implements IKescoGrid
@implements IAsyncDisposable
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using MudBlazor.Extensions
@using MudBlazor.Extensions.Options

@* CascadingValue охватывает весь рендер — и KescoColumnDef (регистрация метаданных),
   и KescoColumn внутри MudDataGrid (построение заголовков) получают одну ссылку на IKescoGrid *@
<CascadingValue Value="(IKescoGrid)this" IsFixed="true">
@ColumnDefs
<MudPaper Elevation="1" Class="pa-4" id="@Id">
    <div class="d-flex flex-wrap justify-space-between gap-2 mb-4" style="align-items:center">
        <MudText Typo="Typo.h5">@Title</MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField T="string"
                          Value="@_searchText"
                          ValueChanged="@OnSearchTextChanged"
                          Placeholder="Поиск..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="max-width:250px;min-width:140px" />
            <KescoButton Text="Настройка колонок"
                         Icon="@Icons.Material.Filled.ViewColumn"
                         Class="toolbar-columns-btn"
                         OnClick="OpenColumnSettings" />
            @if (_columnBySqlName.Values.Any(c => c.Groupable))
            {
                <KescoButton Text="@(_trayExpanded ? "Отключить группировку" : "Группировать")"
                             Icon="@Icons.Material.Filled.AccountTree"
                             Class="@(_trayExpanded ? "grouping-toggle-btn grouping-toggle-btn--active" : "grouping-toggle-btn")"
                             OnClick="@ToggleTray" />
            }
            @if (_columnBySqlName.Values.Any(c => c.Filterable))
            {
                <KescoButton Text="@(_filterTrayExpanded ? "Скрыть фильтры" : "Фильтровать")"
                             Icon="@Icons.Material.Filled.FilterAlt"
                             Class="@(_filterTrayExpanded ? "filter-toggle-btn filter-toggle-btn--active" : "filter-toggle-btn")"
                             OnClick="@ToggleFilterTray" />
            }
            @if (ShowAddButton)
            {
                <KescoButton Text="Добавить"
                             Icon="@Icons.Material.Filled.Add"
                             Class="toolbar-add-btn"
                             OnClick="@OnAdd" />
            }
            @if (SelectVisible)
            {
                <KescoButton Text="@(_selectMode ? "Скрыть выбор" : "Выбрать записи")"
                             Icon="@Icons.Material.Filled.CheckBox"
                             Class="@(_selectMode ? "toolbar-select-btn toolbar-select-btn--active" : "toolbar-select-btn")"
                             OnClick="ToggleSelectMode" />
                <MudMenu Class="toolbar-batch-btn"
                         AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight">
                    <ActivatorContent Context="x">
                        <MudTooltip Text="Групповые операции" Placement="Placement.Bottom">
                            <MudIconButton Icon="@Icons.Material.Filled.PlaylistAddCheck"
                                           Size="Size.Small"
                                             OnClick="async () => { _openSubGroups.Clear(); await x.ToggleAsync(null); }" />
                        </MudTooltip>
                    </ActivatorContent>
                    <ChildContent>
                        @if (ShowPrint)
                        {
                            <MudMenuItem AutoClose="false" OnClick='() => ToggleSubGroup("Печать")'>
                                <div class="batch-menu-header">
                                    <MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                    <span>Печать</span>
                                    <MudIcon Icon="@(IsSubGroupOpen("Печать") ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Style="opacity:0.5" />
                                </div>
                            </MudMenuItem>
                            @if (IsSubGroupOpen("Печать"))
                            {
                                <MudMenuItem OnClick="PrintCurrentPageInternal" Style="padding-left:44px">Текущая страница</MudMenuItem>
                                @if (_selectedCount > 0)
                                {
                                    <MudMenuItem OnClick="PrintSelectedInternal" Style="padding-left:44px">Выбранные (@_selectedCount)</MudMenuItem>
                                }
                                @if (_selectedCount == 0 || _selectAllChecked)
                                {
                                    <MudMenuItem OnClick="PrintAllInternal" Style="padding-left:44px">Все данные</MudMenuItem>
                                }
                            }
                        }
                        @if (ShowExcel)
                        {
                            <MudMenuItem AutoClose="false" OnClick='() => ToggleSubGroup("Excel")'>
                                <div class="batch-menu-header">
                                    <MudIcon Icon="@Icons.Material.Filled.GridOn" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                    <span>Выгрузка в Excel</span>
                                    <MudIcon Icon="@(IsSubGroupOpen("Excel") ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Style="opacity:0.5" />
                                </div>
                            </MudMenuItem>
                            @if (IsSubGroupOpen("Excel"))
                            {
                                <MudMenuItem OnClick="ExcelCurrentPageInternal" Style="padding-left:44px">Текущая страница</MudMenuItem>
                                @if (_selectedCount > 0)
                                {
                                    <MudMenuItem OnClick="ExcelSelectedInternal" Style="padding-left:44px">Выбранные (@_selectedCount)</MudMenuItem>
                                }
                                @if (_selectedCount == 0 || _selectAllChecked)
                                {
                                    <MudMenuItem OnClick="ExcelAllInternal" Style="padding-left:44px">Все данные</MudMenuItem>
                                }
                            }
                        }
                        @if (CustomBatchGroups is not null)
                        {
                            foreach (var group in CustomBatchGroups)
                            {
                                var groupLabel = group.Label;
                                <MudMenuItem AutoClose="false" OnClick="() => ToggleSubGroup(groupLabel)">
                                    <div class="batch-menu-header">
                                        @if (group.Icon is not null)
                                        {
                                            <MudIcon Icon="@group.Icon" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                        }
                                        <span>@groupLabel</span>
                                        <MudIcon Icon="@(IsSubGroupOpen(groupLabel) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Style="opacity:0.5" />
                                    </div>
                                </MudMenuItem>
                                @if (IsSubGroupOpen(groupLabel))
                                {
                                    foreach (var op in group.Operations)
                                    {
                                        var show = (!op.RequiresSelection && !op.RequiresAll)
                                            || (op.RequiresSelection && _selectedCount > 0)
                                            || (op.RequiresAll && (_selectedCount == 0 || _selectAllChecked));
                                        if (show)
                                        {
                                            <MudMenuItem OnClick="async () => { if (op.OnExecute is not null) await op.OnExecute(); }" Style="padding-left:44px">
                                                @if (op.Icon is not null)
                                                {
                                                    <MudIcon Icon="@op.Icon" Size="Size.Small" Class="mr-2" />
                                                }
                                                @op.Label
                                            </MudMenuItem>
                                        }
                                    }
                                }
                            }
                        }
                    </ChildContent>
                </MudMenu>
            }
        </MudStack>
    </div>

    @if (_trayExpanded)
    {
        <div class="grouping-tray d-flex align-items-center flex-wrap gap-2 mb-2"
             @ondragover="OnTrayDragOver"
             @ondragover:preventDefault="true"
             @ondrop="@(e => OnTrayDrop(e, -1))">
            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="grouping-tray-icon" />
            @for (int i = 0; i < _groupColumns.Count; i++)
            {
                var idx = i;
                var col = _groupColumns[i];
                var displayName = _columnBySqlName.TryGetValue(col, out var meta) ? meta.DisplayName : col;
                <div class="grouping-chip"
                     draggable="true"
                     @ondragstart="@(e => OnChipDragStart(e, idx))"
                     @ondragend="OnChipDragEnd"
                     @ondragover="OnTrayDragOver"
                     @ondragover:preventDefault="true"
                     @ondrop="@(e => OnTrayDrop(e, idx))">
                    <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                             Size="Size.Small"
                             Style="margin-right:6px;opacity:0.45;flex-shrink:0;cursor:grab" />
                    <span class="chip-label chip-label-clickable" @onclick="async () => await ToggleSort(col)" @onclick:stopPropagation="true">@displayName</span>
                    @GetSortBadge(col)
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="() => RemoveGroupColumn(col)"
                                   Class="chip-remove-btn pa-0"
                                   Style="width:18px;height:18px" />
                </div>
            }
            @if (_groupColumns.Count == 0)
            {
                <span class="grouping-tray-hint">Перетащите заголовок колонки сюда для группировки</span>
            }
        </div>
    }

    @if (_filterTrayExpanded)
    {
        <div class="filter-tray d-flex align-items-center flex-wrap gap-2 mb-2"
             @ondragover="OnFilterTrayDragOver"
             @ondragover:preventDefault="true"
             @ondrop="OnFilterTrayDrop">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" Class="filter-tray-icon" />
            @foreach (var kv in _activeFilters)
            {
                var sqlName  = kv.Key;
                var filter   = kv.Value;
                var dispName = _columnBySqlName.TryGetValue(sqlName, out var m) ? m.DisplayName : sqlName;
                var desc = KescoColumnFilterDialog.GetFilterDescription(filter, dispName);
                <div class="filter-chip">
                    <span class="chip-label chip-label-clickable"
                          @onclick="async () => await OpenFilterDialog(sqlName, dispName)"
                          @onclick:stopPropagation="true">
                        @desc
                    </span>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="async () => await RemoveFilter(sqlName)"
                                   Class="chip-remove-btn pa-0"
                                   Style="width:18px;height:18px" />
                </div>
            }
            @if (_activeFilters.Count == 0)
            {
                <span class="filter-tray-hint">Перетащите заголовок колонки сюда для фильтрации</span>
            }
        </div>
    }

    <MudDataGrid T="TEntity"
                 @key="_dataKey"
                 Items="@Items"
                 Filterable="false"
                 FixedHeader="true"
                 Height="@_gridHeight"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Loading="@Loading"
                 RowClick="@OnRowClick"
                 RowsPerPage="@_pageSize"
                 MultiSelection="@_selectMode"
                 SelectedItemsChanged="OnSelectedItemsChanged">
        <Columns>
            @if (!_columnsReady)
            {
                @Columns
            }
            else
            {
                @foreach (var colId in _columnOrder)
                {
                    if (!_columnById.TryGetValue(colId, out var ordMeta)) continue;
                    if (_hiddenSqlNames.Contains(ordMeta.SqlName)) continue;
                    if (!_cellTemplates.TryGetValue(colId, out var templateObj)) continue;
                    var sqlName  = ordMeta.SqlName;
                    var dispName = ordMeta.DisplayName;
                    <TemplateColumn @key="colId" T="TEntity"
                                    Title="@dispName"
                                    Sortable="false"
                                    Hidden="@IsGrouped(sqlName)"
                                    DragAndDropEnabled="false">
                        <HeaderTemplate>
                            <div style="display:flex;align-items:center;width:100%">
                                 <div style="flex:1;display:flex;align-items:center;cursor:grab"
                                      draggable="true"
                                      data-col-sql="@sqlName"
                                      @onclick="() => HandleSortClick(sqlName)">
                                    <MudText Style="flex:1;text-align:center">@dispName</MudText>
                                    @GetSortBadge(sqlName)
                                </div>
                                @if (_menuVisible(ordMeta))
                                {
                                    var gSqlName = sqlName;
                                    <MudMenu Class="@("kesco-column-menu" + (ColumnMenuMode == ColumnMenuMode.Mobile ? " column-menu-mobile" : ""))"
                                             AnchorOrigin="Origin.BottomRight"
                                             TransformOrigin="Origin.TopRight">
                                        <ActivatorContent Context="x">
                                            <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                                           Size="Size.Small"
                                                           Style="padding:0;width:22px;height:22px;min-width:22px"
                                                           OnClick="@x.ToggleAsync" />
                                        </ActivatorContent>
                                        <ChildContent>
                                            @if (_trayExpanded && ordMeta.Groupable)
                                            {
                                                <MudMenuItem OnClick="async () => await AddGroupColumn(gSqlName)"
                                                             Icon="@Icons.Material.Filled.AccountTree"
                                                             IconColor="Color.Primary">Группировать</MudMenuItem>
                                            }
                                            @if (_filterTrayExpanded && ordMeta.Filterable)
                                            {
                                                <MudMenuItem OnClick="async () => await ((IKescoGrid)this).AddFilterAsync(gSqlName)"
                                                             Icon="@Icons.Material.Filled.FilterAlt"
                                                             IconColor="Color.Primary">Фильтровать</MudMenuItem>
                                            }
                                        </ChildContent>
                                    </MudMenu>
                                }
                            </div>
                        </HeaderTemplate>
                        <CellTemplate>
                            @{
                                var cellTemplate = (RenderFragment<CellContext<TEntity>>)templateObj;
                            }
                            @cellTemplate(context)
                        </CellTemplate>
                    </TemplateColumn>
                }
            }
        </Columns>
    </MudDataGrid>
    @if (ShowPagination)
    {
        <div class="d-flex flex-wrap justify-space-between gap-2 mt-3" style="align-items:center">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText>Строк на странице:</MudText>
                <MudNumericField T="int" Value="_pageSize" ValueChanged="OnPageSizeChangedAsync" Min="1" Max="999" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:80px" />
                <MudText>Всего: @TotalCount записей</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshAsync" Size="Size.Small" title="Обновить" />
            </MudStack>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" OnClick="GoToFirstPageAsync" Disabled="@(_pageNumber <= 1)" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.NavigateBefore" OnClick="GoToPrevPageAsync" Disabled="@(_pageNumber <= 1)" Size="Size.Small" />
                <MudText Class="mx-2">Стр. @_pageNumber из @_totalPages</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.NavigateNext" OnClick="GoToNextPageAsync" Disabled="@(_pageNumber >= _totalPages)" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.LastPage" OnClick="GoToLastPageAsync" Disabled="@(_pageNumber >= _totalPages)" Size="Size.Small" />
            </MudStack>
        </div>
    }
</MudPaper>
</CascadingValue>

@code {
    // ── Private state ────────────────────────────────────────────────────────────
    private string? _searchText;
    private bool _trayExpanded = false;
    private bool _filterTrayExpanded = false;
    private List<string> _groupColumns = [];
    private int _dragSourceIndex = -1;

    /// <summary>
    /// Состояние сортировки: <c>Column</c> содержит <see cref="KescoColumnMeta.SortName"/>
    /// (реальное выражение для ORDER BY), а не SqlName колонки.
    /// </summary>
    private List<SortColumn> _sortState = [];

    private bool _selectMode;
    private HashSet<TEntity> _selectedItems = [];
    private bool _selectAllChecked;
    private Dictionary<string, bool> _openSubGroups = [];
    private int _selectedCount => _selectedItems.Count;

    private void OnSelectedItemsChanged(HashSet<TEntity> items)
    {
        _selectedItems = items;
        _selectAllChecked = _selectedItems.Count > 0 && Items is not null
            && _selectedItems.Count == Items.Count();
    }

    private Dictionary<string, ColumnFilter> _activeFilters = [];
    private int _pageNumber = 1;
    private int _pageSize;
    private int _dataKey;

    /// <summary>
    /// Срабатывает при регистрации или отмене регистрации колонки.
    /// <see cref="KescoColumn{TEntity}"/> подписывается и вызывает <c>StateHasChanged</c>,
    /// чтобы отобразить <c>DisplayName</c> после того, как <see cref="KescoColumnDef"/>
    /// завершит инициализацию и зарегистрирует метаданные.
    /// </summary>
    public event Action? ColumnsChanged;

    /// <summary>
    /// Срабатывает при открытии или закрытии панели группировки или фильтрации.
    /// <see cref="KescoColumn{TEntity}"/> подписывается и вызывает <c>StateHasChanged</c>,
    /// чтобы показать или скрыть кнопку меню (⋮) в заголовке колонки.
    /// </summary>
    public event Action? TrayStateChanged;

    /// <summary>
    /// Индекс по числовому идентификатору: ColumnId → <see cref="KescoColumnMeta"/>.
    /// Используется <see cref="KescoColumn{TEntity}"/> для поиска метаданных при построении заголовка.
    /// </summary>
    private readonly Dictionary<int, KescoColumnMeta> _columnById = new();

    /// <summary>
    /// Индекс по SQL-имени: SqlName → <see cref="KescoColumnMeta"/>.
    /// Используется для группировки, фильтрации, drag-and-drop и <see cref="IsGrouped"/>.
    /// </summary>
    private readonly Dictionary<string, KescoColumnMeta> _columnBySqlName = new();

    /// <summary>Порядок колонок в гриде (список ColumnId).</summary>
    private readonly List<int> _columnOrder = [];

    /// <summary>SQL-имена колонок, скрытых пользователем через диалог настройки.</summary>
    private readonly HashSet<string> _hiddenSqlNames = [];

    /// <summary>Флаг завершения первой фазы рендеринга (сбор CellTemplate).</summary>
    private bool _columnsReady;

    /// <summary>DotNetObjectReference для передачи в JS (insert-drag заголовков).</summary>
    private DotNetObjectReference<KescoGrid<TEntity>>? _dotnetRef;

    /// <summary>ColumnId → CellTemplate для динамического рендеринга колонок.</summary>
    private readonly Dictionary<int, object> _cellTemplates = [];

    private string _gridHeight
    {
        get
        {
            var trays = (_trayExpanded ? 1 : 0) + (_filterTrayExpanded ? 1 : 0);
            return trays switch
            {
                2 => "calc(100vh - 380px)",
                1 => "calc(100vh - 330px)",
                _ => "calc(100vh - 280px)",
            };
        }
    }

    // ── Parameters ───────────────────────────────────────────────────────────────
    /// <summary>Заголовок грида.</summary>
    [Parameter] public string Title { get; set; } = "Список";

    /// <summary>DOM-идентификатор корневого элемента грида.</summary>
    [Parameter] public string Id { get; set; } = "kesco-grid";

    /// <summary>Данные для отображения.</summary>
    [Parameter] public IEnumerable<TEntity> Items { get; set; } = [];

    /// <summary>Признак загрузки — управляет индикатором грида.</summary>
    [Parameter] public bool Loading { get; set; }

    /// <summary>Показывать кнопку «Добавить» в тулбаре.</summary>
    [Parameter] public bool ShowAddButton { get; set; } = true;

    /// <summary>Количество строк на странице по умолчанию.</summary>
    [Parameter] public int PageSize { get; set; } = 50;

    /// <summary>
    /// Колонки грида — <c>KescoColumn</c> / <c>TemplateColumn</c> / <c>PropertyColumn</c>.
    /// Передаются внутрь <c>MudDataGrid.Columns</c>.
    /// </summary>
    [Parameter] public RenderFragment? Columns { get; set; }

    /// <summary>
    /// Метаданные колонок — <see cref="KescoColumnDef"/> компоненты.
    /// Рендерятся вне грида через <c>CascadingValue</c> для регистрации метаданных.
    /// </summary>
    [Parameter] public RenderFragment? ColumnDefs { get; set; }

    /// <summary>Событие нажатия кнопки «Добавить».</summary>
    [Parameter] public EventCallback OnAdd { get; set; }

    /// <summary>Событие клика по строке грида.</summary>
    [Parameter] public EventCallback<DataGridRowClickEventArgs<TEntity>> OnRowClick { get; set; }

    /// <summary>Событие изменения параметров запроса (поиск, сортировка, пагинация и т.д.).</summary>
    [Parameter] public EventCallback<KescoDataQuery> OnQueryChanged { get; set; }

    /// <summary>Общее количество записей — используется для пагинации.</summary>
    [Parameter] public int TotalCount { get; set; }

    /// <summary>
    /// Текущий номер страницы. Передаётся со страницы для синхронизации
    /// пагинатора при внешних изменениях (например, авто-переход в <c>ToggleGroup</c>).
    /// </summary>
    [Parameter] public int PageNumber { get; set; } = 1;

    /// <summary>Показывать панель пагинации.</summary>
    [Parameter] public bool ShowPagination { get; set; } = true;

    /// <summary>Разрешить перетаскивание колонок.</summary>
    [Parameter] public bool AllowColumnReorder { get; set; } = true;

    /// <summary>
    /// Тип данных для каждой фильтруемой колонки: ключ — SQL-имя, значение — <see cref="ColumnType"/>.
    /// Передаётся из <see cref="KescoGridPageBase{T}.FilterColumnTypes"/>.
    /// </summary>
    [Parameter] public IReadOnlyDictionary<string, ColumnType> FilterColumnTypes { get; set; }
        = new Dictionary<string, ColumnType>();

    /// <summary>Базовый SQL-запрос SELECT (без WHERE / ORDER BY).</summary>
    [Parameter] public string SelectSql { get; set; } = string.Empty;

    /// <summary>Выходные имена колонок SELECT для полнотекстового поиска.</summary>
    [Parameter] public string[] SearchColumns { get; set; } = [];

    /// <summary>Порядок сортировки по умолчанию.</summary>
    [Parameter] public string DefaultOrder { get; set; } = string.Empty;

    /// <summary>
    /// Тип компонента диалога редактирования.
    /// Диалог должен принимать параметр <c>Model</c> типа сущности.
    /// </summary>
    [Parameter] public Type? EditDialogType { get; set; }

    /// <summary>
    /// Загрузчик данных страницы. Передаётся как <c>DataLoader="this"</c> со страницы,
    /// наследующей <see cref="KescoGridPageBase{T}"/>.
    /// Если задан, <see cref="NotifyQueryChanged"/> вызывает его вместо <see cref="OnQueryChanged"/>.
    /// </summary>
    [Parameter] public IKescoGridDataLoader? DataLoader { get; set; }

    /// <summary>
    /// Режим отображения кнопки меню (⋮) в заголовках колонок.
    /// <c>Hidden</c> — всегда скрыта, <c>Always</c> — всегда видна,
    /// <c>Mobile</c> — только на мобильных (≤960px, по умолчанию).
    /// </summary>
    [Parameter] public ColumnMenuMode ColumnMenuMode { get; set; } = ColumnMenuMode.Mobile;

    /// <summary>Показывать кнопку выбора записей (чекбоксы).</summary>
    [Parameter] public bool SelectVisible { get; set; }

    /// <summary>Показывать группу «Печать» в меню групповых операций.</summary>
    [Parameter] public bool ShowPrint { get; set; }

    /// <summary>Показывать группу «Выгрузка в Excel» в меню групповых операций.</summary>
    [Parameter] public bool ShowExcel { get; set; }

    /// <summary>
    /// Кастомные группы операций для меню групповых операций.
    /// Каждая группа рендерится как подменю со своими операциями.
    /// Обработчики (<see cref="BatchOperation.OnExecute"/>) реализуются в приложении.
    /// </summary>
    [Parameter] public IReadOnlyList<BatchOperationGroup>? CustomBatchGroups { get; set; }

    /// <summary>SQL-имена колонок текущей группировки.</summary>
    public IReadOnlyList<string> GroupColumns => _groupColumns.AsReadOnly();

    /// <summary>Выбранные в данный момент строки (режим выбора).</summary>
    public IReadOnlyCollection<TEntity> SelectedItems => _selectedItems;

    private int _totalPages => _pageSize > 0 && TotalCount > 0 ? (int)Math.Ceiling((double)TotalCount / _pageSize) : 1;

    // ── Lifecycle ────────────────────────────────────────────────────────────────
    /// <inheritdoc/>
    protected override void OnInitialized()
    {
        _pageSize = PageSize;
    }

    /// <inheritdoc/>
    protected override void OnParametersSet()
    {
        _pageNumber = PageNumber;
        if (TotalCount > 0 && _pageNumber > _totalPages)
            _pageNumber = _totalPages;
    }

    /// <inheritdoc/>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _columnsReady = true;
            _dataKey++;
            StateHasChanged();
        }
        else if (_columnsReady && !string.IsNullOrEmpty(Id))
        {
            // Реинициализируем drag после каждого ре-рендера динамических колонок.
            // kescoGridColumnDrag.init() безопасно вызывается многократно — внутри dispose предыдущего.
            _dotnetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("kescoGridColumnDrag.init", Id, _dotnetRef);
        }
    }

    /// <summary>
    /// Вызывается из JS после завершения drag-and-drop заголовка колонки.
    /// Обновляет <see cref="_columnOrder"/> через insert (не swap).
    /// </summary>
    /// <param name="srcSql">SQL-имя перетаскиваемой колонки.</param>
    /// <param name="targetSql">SQL-имя целевой колонки (относительно которой вставляем).</param>
    /// <param name="insertBefore"><c>true</c> — вставить перед <paramref name="targetSql"/>, <c>false</c> — после.</param>
    /// <summary>
    /// Вызывается из JS при начале drag заголовка колонки.
    /// Устанавливает <see cref="KescoDragState.DraggedColumn"/> для tray-drop обработчиков.
    /// </summary>
    [JSInvokable]
    public void SetDraggedColumn(string? sqlName)
        => KescoDragState.DraggedColumn = sqlName;

    [JSInvokable]
    public void OnColumnDrop(string srcSql, string targetSql, bool insertBefore)
    {
        if (!_columnBySqlName.TryGetValue(srcSql, out var srcMeta)) return;
        if (!_columnBySqlName.TryGetValue(targetSql, out var tgtMeta)) return;

        var srcId = srcMeta.ColumnId;
        var tgtId = tgtMeta.ColumnId;

        var srcIdx = _columnOrder.IndexOf(srcId);
        var tgtIdx = _columnOrder.IndexOf(tgtId);
        if (srcIdx < 0 || tgtIdx < 0 || srcIdx == tgtIdx) return;

        _columnOrder.RemoveAt(srcIdx);
        // После удаления источника пересчитываем целевой индекс
        tgtIdx = _columnOrder.IndexOf(tgtId);
        var insertAt = insertBefore ? tgtIdx : tgtIdx + 1;
        insertAt = Math.Clamp(insertAt, 0, _columnOrder.Count);
        _columnOrder.Insert(insertAt, srcId);

        _dataKey++;
        InvokeAsync(StateHasChanged);
    }

    /// <inheritdoc/>
    public async ValueTask DisposeAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            try { await JS.InvokeVoidAsync("kescoGridColumnDrag.dispose", Id); } catch { }
        }
        _dotnetRef?.Dispose();
    }

    private void ToggleSelectMode()
    {
        _selectMode = !_selectMode;
        if (!_selectMode)
            _selectedItems.Clear();
