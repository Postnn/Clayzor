@using Kesco.Lib.Web.BZ.Controls.Components.Grid
@using Kesco.Lib.Web.BZ.Controls.Components.Grid.ColumnTypes

@* Редактор одного листового условия составного фильтра.
   Колонка, оператор и значение — в одну строку. Кнопка удаления справа. *@

<div style="display:flex;flex-direction:column;gap:8px;padding:8px;border:1px solid var(--mud-palette-lines-default);border-radius:4px">
    <div style="display:flex;gap:8px;align-items:flex-start">

        @* ── Выбор колонки ────────────────────────────────────────── *@
        <MudSelect T="string"
                   Label="Поле"
                   Value="@Node.Column"
                   ValueChanged="@OnColumnChanged"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomLeft"
                   Style="min-width:160px;flex:1">
            @foreach (var col in Columns)
            {
                <MudSelectItem Value="@col.SqlName">@col.DisplayName</MudSelectItem>
            }
        </MudSelect>

        @* ── Выбор оператора ──────────────────────────────────────── *@
        <MudSelect T="ColumnFilterOperator"
                   Label="Условие"
                   Value="@Node.Operator"
                   ValueChanged="@OnOperatorChanged"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomLeft"
                   Style="min-width:160px;flex:1"
                   Disabled="@(_descriptor is null)">
            @foreach (var op in _availableOperators)
            {
                <MudSelectItem Value="@op">@KescoFilterOperatorLabels.Get(op)</MudSelectItem>
            }
        </MudSelect>

        @* ── Кнопка удаления ──────────────────────────────────────── *@
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       OnClick="@OnRemove"
                       Style="margin-top:4px"
                       title="Удалить условие" />
    </div>

    @* ── Редактор значения ────────────────────────────────────────── *@
    @if (_descriptor is not null)
    {
        <KescoFilterValueEditor Type="@_descriptor"
                                Value="@Node.Value"
                                ValueChanged="@OnValueChanged"
                                Options="@_options"
                                Operator="@Node.Operator" />
    }
</div>
