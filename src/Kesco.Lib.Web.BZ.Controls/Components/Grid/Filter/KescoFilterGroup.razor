@using Kesco.Lib.Web.BZ.Controls.Components.Grid
@using Kesco.Lib.Web.BZ.Controls.Components.Grid.ColumnTypes

@* Рекурсивный узел-группа составного фильтра.
   Может содержать листья (KescoFilterExpression) и вложенные группы (KescoFilterGroup). *@

<div style="@(IsRoot
    ? "display:flex;flex-direction:column;gap:6px;padding:6px 0"
    : "display:flex;flex-direction:column;gap:6px;padding:6px 6px 6px 8px;border-left:2px solid var(--mud-palette-primary)")">

    @* ── Заголовок группы: И/ИЛИ + добавление + удаление ── *@
    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
        <MudToggleGroup T="LogicalOperator"
                        Value="@Node.Logic"
                        ValueChanged="@SetLogic"
                        Color="Color.Primary"
                        Size="Size.Small"
                        CheckMark="false"
                        SelectionMode="SelectionMode.SingleSelection">
            <MudToggleItem Value="@LogicalOperator.And" Text="И" />
            <MudToggleItem Value="@LogicalOperator.Or" Text="ИЛИ" />
        </MudToggleGroup>

        <MudButton Variant="Variant.Text" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@AddExpression" Style="text-transform:none">
            добавить условие
        </MudButton>
        <MudButton Variant="Variant.Text" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.CreateNewFolder"
                   OnClick="@AddGroup" Style="text-transform:none">
            добавить группу
        </MudButton>

        <MudSpacer />

        @if (!IsRoot)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="@OnRemove"
                           title="Удалить группу" />
        }
    </div>

    @* ── Дочерние узлы ────────────────────────────────────────────── *@
    @for (int i = 0; i < Node.Nodes.Count; i++)
    {
        var node = Node.Nodes[i];
        var capturedIndex = i;

        @if (node is ColumnFilter leaf)
        {
            @if (leaf.Source == KescoFilterSource.ColumnDialog)
            {
                @* Условия из диалога колонки — не редактируются здесь, только удаляются *@
                <div style="display:flex;align-items:center;gap:8px;padding:6px 8px;
                            border:1px solid var(--mud-palette-lines-default);border-radius:4px;
                            color:var(--mud-palette-text-secondary);font-size:var(--kesco-font-size)">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Style="flex:1 1 auto">
                        Редактируется в диалоге колонки: @GetLeafDescription(leaf)
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="@(() => RemoveNode(capturedIndex))"
                                   title="Удалить условие" Style="flex:0 0 auto" />
                </div>
            }
            else
            {
                <KescoFilterExpression Node="@leaf"
                                       Columns="@Columns"
                                       LookupOptions="@LookupOptions"
                                       OnChanged="@NotifyChanged"
                                       OnRemove="@(() => RemoveNode(capturedIndex))" />
            }
        }
        else if (node is KescoFilterGroupNode group)
        {
            <KescoFilterGroup Node="@group"
                              Columns="@Columns"
                              LookupOptions="@LookupOptions"
                              IsRoot="false"
                              OnChanged="@NotifyChanged"
                              OnRemove="@(() => RemoveNode(capturedIndex))" />
        }
    }

</div>
