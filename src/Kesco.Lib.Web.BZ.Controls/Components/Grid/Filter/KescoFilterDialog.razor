@using Kesco.Lib.Web.BZ.Controls.Components.Grid
@using Kesco.Lib.Web.BZ.Controls.Components.Grid.ColumnTypes

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="display:flex;align-items:center;gap:8px">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
            Настраиваемый фильтр
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="min-width:480px;max-width:700px;max-height:60vh;overflow-y:auto">
            @if (!string.IsNullOrEmpty(_draftDescription))
            {
                <MudPaper Elevation="0" Class="pa-2 mb-2" Style="background:var(--mud-palette-background-grey)">
                    <MudText Typo="Typo.body2">@_draftDescription</MudText>
                </MudPaper>
            }
            <KescoFilterGroup Node="@_draft"
                              Columns="@Columns"
                              LookupOptions="@LookupOptions"
                              IsRoot="true"
                              OnChanged="@OnDraftChanged" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Reset"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ClearAll"
                   Style="text-transform:none">
            Сбросить
        </MudButton>
        <MudSpacer />
        <MudButton OnClick="@Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="@Apply">
            Применить
        </MudButton>
    </DialogActions>
</MudDialog>
