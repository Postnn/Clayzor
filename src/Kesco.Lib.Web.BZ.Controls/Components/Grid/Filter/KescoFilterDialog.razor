@using Kesco.Lib.Web.BZ.Controls.Components.Grid
@using Kesco.Lib.Web.BZ.Controls.Components.Grid.ColumnTypes

<MudDialog ContentClass="kesco-filter-dialog-content">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="display:flex;align-items:center;gap:8px">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
            @KescoFilterStrings.DialogTitle
        </MudText>
    </TitleContent>

    <DialogContent>
        @* Прямые дети .mud-dialog-content (без обёртки!), чтобы работал flex-скролл *@

        @if (!string.IsNullOrEmpty(_draftDescription))
        {
            <MudPaper Elevation="0" Class="pa-1 kesco-filter-dialog__panel">
                <MudText Typo="Typo.body2">@_draftDescription</MudText>
            </MudPaper>
        }

        <div style="flex:1 1 auto;overflow-y:auto;min-height:0">
            <KescoFilterGroup Node="@_draft"
                              Columns="@Columns"
                              LookupOptions="@LookupOptions"
                              IsRoot="true"
                              OnChanged="@OnDraftChanged" />
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="@Reset" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ClearAll"
                   Class="kesco-text-normal">@KescoFilterStrings.Reset</MudButton>
        <MudSpacer />
        <MudButton OnClick="@Cancel" Variant="Variant.Text">@KescoFilterStrings.Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="@Apply">@KescoFilterStrings.Apply</MudButton>
    </DialogActions>
</MudDialog>

<style>
    /* ContentClass кладёт этот класс прямо на .mud-dialog-content — надёжнее, чем Class на MudDialog */
    .kesco-filter-dialog-content {
        width: 600px; max-width: 100%; height: min(460px, 80vh);
        overflow: hidden; display: flex; flex-direction: column; gap: 4px;
    }
</style>
