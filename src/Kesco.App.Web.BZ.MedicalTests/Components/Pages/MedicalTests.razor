@page "/medical-tests"
@using Kesco.Lib.Web.Settings
@using Kesco.Lib.Web.BZ.Controls
@inherits KescoGridPageBase<MedicalTest>
@inject KescoAppSettings AppSettings

<PageTitle>Медицинские исследования</PageTitle>

<CascadingValue Value="(IKescoGridDataLoader)this" IsFixed="true">
<KescoGrid TEntity="IGridRow"
           @ref="_dataGrid"
           Title="Медицинские исследования"
           SelectSql="@SQLQueries.SELECT_МедицинскиеАнализы"
           SearchColumns="@(new[]{"НазваниеАнализа","TestTypeName"})"
           DefaultOrder="Порядок, НазваниеАнализа"
           EditDialogType="@typeof(MedicalTestEditDialog)"
           Items="_rows"
           Loading="_loading"
           PageSize="@AppSettings.DefaultPageSize"
           FilterColumnTypes="@FilterColumnTypes"
           TotalCount="@_query.TotalCount"
           ShowPagination="true"
           OnAdd="OpenAddDialog"
           OnRowClick="OnRowClicked">

    <ColumnDefs>
        <KescoColumnDef SqlName="TestTypeName"            DisplayName="Тип"         Groupable="true" Filterable="true" />
        <KescoColumnDef SqlName="КодМедицинскогоАнализа" DisplayName="Код"         Groupable="true" Filterable="true" />
        <KescoColumnDef SqlName="НазваниеАнализа"        DisplayName="Название"    Groupable="true" Filterable="true" />
        <KescoColumnDef SqlName="Порядок"                DisplayName="Порядок"     Groupable="true" Filterable="true" />
        <KescoColumnDef SqlName="Группа"                 DisplayName="Группа"                       Filterable="true" />
        <KescoColumnDef SqlName="Заключение"             DisplayName="Заключение"                   Filterable="true" />
    </ColumnDefs>

    <Columns>

        <TemplateColumn T="IGridRow" Title="Код" Sortable="false"
                        Hidden="@(_dataGrid?.IsGrouped("КодМедицинскогоАнализа") ?? false)">
            <HeaderTemplate>
                <KescoSortableColumnHeader SqlName="КодМедицинскогоАнализа" DisplayName="Код" Grid="_dataGrid" />
            </HeaderTemplate>
            <CellTemplate>
                @if (context.Item is GroupHeaderRow header)
                {
                    <KescoGroupHeader Header="header" OnToggle="ToggleGroup" />
                }
                else if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText Style="@($"padding-left:{(detail.Depth + 1) * 16}px")">@detail.Item.Id</MudText>
                }
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="IGridRow" Title="Название" Sortable="false"
                        Hidden="@(_dataGrid?.IsGrouped("НазваниеАнализа") ?? false)">
            <HeaderTemplate>
                <KescoSortableColumnHeader SqlName="НазваниеАнализа" DisplayName="Название" Grid="_dataGrid" />
            </HeaderTemplate>
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText>@detail.Item.Name</MudText>
                }
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="IGridRow" Title="Тип" Sortable="false"
                        Hidden="@(_dataGrid?.IsGrouped("TestTypeName") ?? false)">
            <HeaderTemplate>
                <KescoSortableColumnHeader SqlName="TestTypeName" DisplayName="Тип" Grid="_dataGrid" />
            </HeaderTemplate>
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText>@detail.Item.TestTypeName</MudText>
                }
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="IGridRow" Title="Порядок" Sortable="false"
                        Hidden="@(_dataGrid?.IsGrouped("Порядок") ?? false)">
            <HeaderTemplate>
                <KescoSortableColumnHeader SqlName="Порядок" DisplayName="Порядок" Grid="_dataGrid" />
            </HeaderTemplate>
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText>@detail.Item.Order</MudText>
                }
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="IGridRow" Title="Группа">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudIcon Icon="@(detail.Item.IsGroup ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(detail.Item.IsGroup ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                }
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="IGridRow" Title="Заключение">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudIcon Icon="@(detail.Item.IsConclusion ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(detail.Item.IsConclusion ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                }
            </CellTemplate>
        </TemplateColumn>

    </Columns>

</KescoGrid>
</CascadingValue>

@code {
    // Поле конкретного типа нужно для @ref и вызовов UI-методов (ToggleSort, GetSortBadge, GroupColumns).
    // Grid в базовом классе заполняется через переопределение свойства.
    private KescoGrid<IGridRow> _dataGrid = null!;
    protected override IKescoGrid? Grid => _dataGrid;
}
