@page "/medical-tests"
@using Kesco.Lib.Web.Settings
@using Kesco.Lib.Web.BZ.Controls
@inherits KescoGridPageBase<MedicalTest>
@inject KescoAppSettings AppSettings

<PageTitle>Медицинские исследования</PageTitle>

<KescoGrid TEntity="IGridRow"
           @ref="_dataGrid"
           DataLoader="this"
           Title="Медицинские исследования"
           SelectSql="@SQLQueries.SELECT_МедицинскиеАнализы"
           SearchColumns="@(new[]{"НазваниеАнализа","TestTypeName"})"
           DefaultOrder="Порядок, НазваниеАнализа"
           EditDialogType="@typeof(MedicalTestEditDialog)"
           Items="_rows"
           Loading="_loading"
           PageSize="@AppSettings.DefaultPageSize"
           FilterColumnTypes="@FilterColumnTypes"
           TotalCount="@_query.TotalCount"
           ShowPagination="true"
            ColumnMenuMode="@ColumnMenuMode.Always"
            SelectVisible="true"
            OnPrintCurrentPage="PrintCurrentPage"
            OnPrintAll="PrintAll"
            OnPrintSelected="PrintSelected"
            OnExcelCurrentPage="ExcelCurrentPage"
            OnExcelAll="ExcelAll"
            OnExcelSelected="ExcelSelected"
            OnAdd="OpenAddDialog"
           OnRowClick="OnRowClicked">

    <ColumnDefs>
        <KescoColumnDef ColumnId="1" SqlName="TestTypeName"            DisplayName="Тип"         Groupable="true" Filterable="true" />
        <KescoColumnDef ColumnId="2" SqlName="КодМедицинскогоАнализа" DisplayName="Код"         Groupable="true" Filterable="true" />
        <KescoColumnDef ColumnId="3" SqlName="НазваниеАнализа"        DisplayName="Название"    Groupable="true" Filterable="true" />
        <KescoColumnDef ColumnId="4" SqlName="Порядок"                DisplayName="Порядок"     Groupable="true" Filterable="true" />
        <KescoColumnDef ColumnId="5" SqlName="Группа"                 DisplayName="Группа"                       Filterable="true" />
        <KescoColumnDef ColumnId="6" SqlName="Заключение"             DisplayName="Заключение"                   Filterable="true" />
    </ColumnDefs>

    <Columns>

        <KescoColumn TEntity="IGridRow" ColumnId="2">
            <CellTemplate>
                @if (context.Item is GroupHeaderRow header)
                {
                    <KescoGroupHeader Header="header" OnToggle="ToggleGroup" />
                }
                else if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText Style="@($"padding-left:{(detail.Depth + 1) * 16}px")">@detail.Item.Id</MudText>
                }
            </CellTemplate>
        </KescoColumn>

        <KescoColumn TEntity="IGridRow" ColumnId="3">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText>@detail.Item.Name</MudText>
                }
            </CellTemplate>
        </KescoColumn>

        <KescoColumn TEntity="IGridRow" ColumnId="1">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText>@detail.Item.TestTypeName</MudText>
                }
            </CellTemplate>
        </KescoColumn>

        <KescoColumn TEntity="IGridRow" ColumnId="4">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudText>@detail.Item.Order</MudText>
                }
            </CellTemplate>
        </KescoColumn>

        <KescoColumn TEntity="IGridRow" ColumnId="5">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudIcon Icon="@(detail.Item.IsGroup ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(detail.Item.IsGroup ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                }
            </CellTemplate>
        </KescoColumn>

        <KescoColumn TEntity="IGridRow" ColumnId="6">
            <CellTemplate>
                @if (context.Item is DetailRow<MedicalTest> detail)
                {
                    <MudIcon Icon="@(detail.Item.IsConclusion ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(detail.Item.IsConclusion ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                }
            </CellTemplate>
        </KescoColumn>

    </Columns>

</KescoGrid>

@code {
    // Поле конкретного типа нужно для @ref и вызовов UI-методов (ToggleSort, GetSortBadge, GroupColumns).
    // Grid в базовом классе заполняется через переопределение свойства.
    private KescoGrid<IGridRow> _dataGrid = null!;
    protected override IKescoGrid? Grid => _dataGrid;

    private async Task PrintCurrentPage()
    {
        var ids = _dataGrid.SelectedItems.OfType<DetailRow<MedicalTest>>().Select(d => d.Item.Id).ToList();
        Snackbar.Add($"Печать текущей страницы — в разработке", Severity.Info);
    }

    private async Task PrintAll()
    {
        Snackbar.Add($"Печать всех данных списка — в разработке", Severity.Info);
    }

    private async Task PrintSelected()
    {
        var ids = _dataGrid.SelectedItems.OfType<DetailRow<MedicalTest>>().Select(d => d.Item.Id).ToList();
        Snackbar.Add($"Печать {ids.Count} выбранных записей — в разработке", Severity.Info);
    }

    private async Task ExcelCurrentPage()
    {
        var ids = _dataGrid.SelectedItems.OfType<DetailRow<MedicalTest>>().Select(d => d.Item.Id).ToList();
        Snackbar.Add($"Выгрузка текущей страницы в Excel — в разработке", Severity.Info);
    }

    private async Task ExcelAll()
    {
        Snackbar.Add($"Выгрузка всех данных в Excel — в разработке", Severity.Info);
    }

    private async Task ExcelSelected()
    {
        var ids = _dataGrid.SelectedItems.OfType<DetailRow<MedicalTest>>().Select(d => d.Item.Id).ToList();
        Snackbar.Add($"Выгрузка {ids.Count} записей в Excel — в разработке", Severity.Info);
    }
}
