@page "/medical-tests"
@using Kesco.Lib.DALC
@using Kesco.Lib.Web.Settings
@using Kesco.Lib.Web.BZ.Controls

@inject DbManager Db
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject KescoAppSettings AppSettings
@inject KescoErrorService ErrorService

<PageTitle>Медицинские исследования</PageTitle>

<KescoDataList TEntity="MedicalTest"
               @ref="_dataGrid"
               Title="Медицинские исследования"
               Items="_tests"
               Loading="_loading"
               PageSize="@AppSettings.DefaultPageSize"
               ShowGroupingTray="true"
               AvailableGroupColumns="@_groupColumnsDef"
               Groupable="@(_dataGrid?.GroupColumns.Count > 0)"
               TotalCount="@_query.TotalCount"
               ShowPagination="true"
               OnAdd="OpenAddDialog"
               OnRowClick="OnRowClicked"
               OnQueryChanged="OnQueryChanged">
    <PropertyColumn T="MedicalTest" TProperty="int" Property="x => x.Id" Sortable="false"
                    Title="Код"
                    Groupable="true"
                    Grouping="@(_dataGrid?.GroupColumns.Contains("КодМедицинскогоАнализа") ?? false)"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("КодМедицинскогоАнализа") ?? false)"
                    GroupByOrder="@(_dataGrid?.GetGroupByOrder("КодМедицинскогоАнализа") ?? 0)"
                    GroupBy="@(x => x.Id)">
        <HeaderTemplate>
             <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                  draggable="true"
                  @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "КодМедицинскогоАнализа"; })"
                  @onclick="@(() => _dataGrid?.ToggleSort("КодМедицинскогоАнализа"))">
                <MudText Style="flex:1;text-align:center">Код</MudText>
                @if (_dataGrid is not null)
                {
                    @_dataGrid.GetSortBadge("КодМедицинскогоАнализа")
                }
            </div>
        </HeaderTemplate>
        <GroupTemplate>
            <MudText Typo="Typo.body1" Style="font-weight:600">
                @context.Grouping!.Key (@context.Grouping!.Count() шт.)
            </MudText>
        </GroupTemplate>
    </PropertyColumn>
    <PropertyColumn T="MedicalTest" TProperty="string" Property="x => x.Name" Sortable="false"
                    Title="Название"
                    Groupable="true"
                    Grouping="@(_dataGrid?.GroupColumns.Contains("НазваниеАнализа") ?? false)"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("НазваниеАнализа") ?? false)"
                    GroupByOrder="@(_dataGrid?.GetGroupByOrder("НазваниеАнализа") ?? 0)"
                    GroupBy="@(x => x.Name ?? "")">
        <HeaderTemplate>
             <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                  draggable="true"
                  @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "НазваниеАнализа"; })"
                  @onclick="@(() => _dataGrid?.ToggleSort("НазваниеАнализа"))">
                <MudText Style="flex:1;text-align:center">Название</MudText>
                @if (_dataGrid is not null)
                {
                    @_dataGrid.GetSortBadge("НазваниеАнализа")
                }
            </div>
        </HeaderTemplate>
        <GroupTemplate>
            <MudText Typo="Typo.body1" Style="font-weight:600">
                @context.Grouping!.Key (@context.Grouping!.Count() шт.)
            </MudText>
        </GroupTemplate>
    </PropertyColumn>
    <PropertyColumn T="MedicalTest" TProperty="string" Property="x => x.TestTypeName" Sortable="false"
                    Title="Тип"
                    Groupable="true"
                    Grouping="@(_dataGrid?.GroupColumns.Contains("TestTypeName") ?? false)"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("TestTypeName") ?? false)"
                    GroupByOrder="@(_dataGrid?.GetGroupByOrder("TestTypeName") ?? 0)"
                    GroupBy="@(x => x.TestTypeName ?? "")">
        <HeaderTemplate>
             <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                  draggable="true"
                  @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "TestTypeName"; })"
                  @onclick="@(() => _dataGrid?.ToggleSort("TestTypeName"))">
                <MudText Style="flex:1;text-align:center">Тип</MudText>
                @if (_dataGrid is not null)
                {
                    @_dataGrid.GetSortBadge("TestTypeName")
                }
            </div>
        </HeaderTemplate>
        <GroupTemplate>
            <MudText Typo="Typo.body1" Style="font-weight:600">
                @context.Grouping!.Key (@context.Grouping!.Count() шт.)
            </MudText>
        </GroupTemplate>
    </PropertyColumn>
    <PropertyColumn T="MedicalTest" TProperty="int" Property="x => x.Order" Sortable="false"
                    Title="Порядок"
                    Groupable="true"
                    Grouping="@(_dataGrid?.GroupColumns.Contains("Порядок") ?? false)"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("Порядок") ?? false)"
                    GroupByOrder="@(_dataGrid?.GetGroupByOrder("Порядок") ?? 0)"
                    GroupBy="@(x => x.Order)">
        <HeaderTemplate>
             <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                  draggable="true"
                  @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "Порядок"; })"
                  @onclick="@(() => _dataGrid?.ToggleSort("Порядок"))">
                <MudText Style="flex:1;text-align:center">Порядок</MudText>
                @if (_dataGrid is not null)
                {
                    @_dataGrid.GetSortBadge("Порядок")
                }
            </div>
        </HeaderTemplate>
        <GroupTemplate>
            <MudText Typo="Typo.body1" Style="font-weight:600">
                @context.Grouping!.Key (@context.Grouping!.Count() шт.)
            </MudText>
        </GroupTemplate>
    </PropertyColumn>
    <TemplateColumn T="MedicalTest" Title="Группа">
        <CellTemplate>
            <MudIcon Icon="@(context.Item.IsGroup ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                     Color="@(context.Item.IsGroup ? Color.Success : Color.Default)"
                     Size="Size.Small" />
        </CellTemplate>
    </TemplateColumn>
    <TemplateColumn T="MedicalTest" Title="Заключение">
        <CellTemplate>
            <MudIcon Icon="@(context.Item.IsConclusion ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                     Color="@(context.Item.IsConclusion ? Color.Success : Color.Default)"
                     Size="Size.Small" />
        </CellTemplate>
    </TemplateColumn>
</KescoDataList>

@code {
    private KescoDataList<MedicalTest> _dataGrid = null!;
    private KescoDataQuery _query = new();

    private Dictionary<string, string> _groupColumnsDef = new()
    {
        ["Тип"] = "TestTypeName",
        ["Код"] = "КодМедицинскогоАнализа",
        ["Название"] = "НазваниеАнализа",
        ["Порядок"] = "Порядок"
    };

    private List<MedicalTest> _tests = [];
    private bool _loading = true;

    private async Task OnQueryChanged(KescoDataQuery query)
    {
        _query.SearchText = query.SearchText;
        _query.GroupEnabled = query.GroupEnabled;
        _query.GroupColumns = query.GroupColumns;
        _query.SortColumns = query.SortColumns;
        _query.PageNumber = query.PageNumber;
        _query.PageSize = query.PageSize;
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        var orderBy = _query.BuildOrderBy("Порядок, НазваниеАнализа");
        var where = _query.BuildWhereClause("a.НазваниеАнализа", "t.ТипМедицинскогоАнализа");
        var param = new { search = $"%{_query.SearchText}%" };

        try
        {
            _query.TotalCount = await MedicalTest.GetCountAsync(Db, where, param);
            _tests = (await MedicalTest.GetPagedAsync(Db, where, orderBy, param, _query.PageNumber, _query.PageSize)).ToList();
        }
        catch (Exception)
        {
            // DbManager уже передал ошибку в KescoErrorService через ISqlErrorHandler
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenAddDialog()
    {
        var model = new MedicalTest();
        var parameters = new DialogParameters<MedicalTestEditDialog>
        {
            { x => x.Model, model }
        };
        var options = new DialogOptionsEx { MaxWidth = MaxWidth.Small, FullWidth = true, DragMode = MudDialogDragMode.Simple };
        var dialog = await DialogService.ShowExAsync<MedicalTestEditDialog>("Новое исследование", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Запись добавлена", Severity.Success);
            await LoadData();
        }
    }

    private async Task OnRowClicked(DataGridRowClickEventArgs<MedicalTest> args)
    {
        var parameters = new DialogParameters<MedicalTestEditDialog>
        {
            { x => x.Model, args.Item }
        };
        var options = new DialogOptionsEx { MaxWidth = MaxWidth.Small, FullWidth = true, DragMode = MudDialogDragMode.Simple };
        var dialog = await DialogService.ShowExAsync<MedicalTestEditDialog>("Редактирование", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Запись обновлена", Severity.Success);
        }
        await LoadData();
    }
}
