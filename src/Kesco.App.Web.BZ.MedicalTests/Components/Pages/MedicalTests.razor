@page "/medical-tests"
@using Kesco.Lib.Web.Settings
@using Kesco.Lib.Web.BZ.Controls
@using MudBlazor.Extensions
@using MudBlazor.Extensions.Options
@inherits KescoGridPageBase<MedicalTest>

@inject IDialogService DialogService
@inject KescoAppSettings AppSettings

<PageTitle>Медицинские исследования</PageTitle>

<KescoGrid TEntity="IGridRow"
           @ref="_dataGrid"
           Title="Медицинские исследования"
           Items="_rows"
           Loading="_loading"
           PageSize="@AppSettings.DefaultPageSize"
           ShowGroupingTray="true"
           AvailableGroupColumns="@_groupColumnsDef"
           ShowFilterTray="true"
           AvailableFilterColumns="@_filterColumnsDef"
           FilterColumnTypes="@_filterColumnTypes"
           TotalCount="@_query.TotalCount"
           ShowPagination="true"
           OnAdd="OpenAddDialog"
           OnRowClick="OnRowClicked"
           OnQueryChanged="OnQueryChanged">

    <TemplateColumn T="IGridRow" Title="Код" Sortable="false"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("КодМедицинскогоАнализа") ?? false)">
        <HeaderTemplate>
            <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                 draggable="true"
                 @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "КодМедицинскогоАнализа"; })"
                 @onclick="@(async () => { if (_dataGrid is not null) await _dataGrid.ToggleSort("КодМедицинскогоАнализа"); })">
                <MudText Style="flex:1;text-align:center">Код</MudText>
                @if (_dataGrid is not null) { @_dataGrid.GetSortBadge("КодМедицинскогоАнализа") }
            </div>
        </HeaderTemplate>
        <CellTemplate>
            @if (context.Item is GroupHeaderRow header)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Style="@($"padding-left:{header.Depth * 16}px")">
                    <MudIconButton Icon="@(header.IsExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                   Size="Size.Small"
                                   OnClick="() => ToggleGroup(header)"
                                   Style="padding:0;width:22px;height:22px;min-width:22px" />
                    <MudText Style="font-weight:600;font-size:0.875rem">@header.DisplayValue (@header.ItemCount шт.)</MudText>
                </MudStack>
            }
            else if (context.Item is DetailRow<MedicalTest> detail)
            {
                <MudText Style="@($"padding-left:{(detail.Depth + 1) * 16}px")">@detail.Item.Id</MudText>
            }
        </CellTemplate>
    </TemplateColumn>

    <TemplateColumn T="IGridRow" Title="Название" Sortable="false"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("НазваниеАнализа") ?? false)">
        <HeaderTemplate>
            <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                 draggable="true"
                 @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "НазваниеАнализа"; })"
                 @onclick="@(async () => { if (_dataGrid is not null) await _dataGrid.ToggleSort("НазваниеАнализа"); })">
                <MudText Style="flex:1;text-align:center">Название</MudText>
                @if (_dataGrid is not null) { @_dataGrid.GetSortBadge("НазваниеАнализа") }
            </div>
        </HeaderTemplate>
        <CellTemplate>
            @if (context.Item is DetailRow<MedicalTest> detail)
            {
                <MudText>@detail.Item.Name</MudText>
            }
        </CellTemplate>
    </TemplateColumn>

    <TemplateColumn T="IGridRow" Title="Тип" Sortable="false"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("TestTypeName") ?? false)">
        <HeaderTemplate>
            <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                 draggable="true"
                 @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "TestTypeName"; })"
                 @onclick="@(async () => { if (_dataGrid is not null) await _dataGrid.ToggleSort("TestTypeName"); })">
                <MudText Style="flex:1;text-align:center">Тип</MudText>
                @if (_dataGrid is not null) { @_dataGrid.GetSortBadge("TestTypeName") }
            </div>
        </HeaderTemplate>
        <CellTemplate>
            @if (context.Item is DetailRow<MedicalTest> detail)
            {
                <MudText>@detail.Item.TestTypeName</MudText>
            }
        </CellTemplate>
    </TemplateColumn>

    <TemplateColumn T="IGridRow" Title="Порядок" Sortable="false"
                    Hidden="@(_dataGrid?.GroupColumns.Contains("Порядок") ?? false)">
        <HeaderTemplate>
            <div style="display:flex;align-items:center;width:100%;cursor:pointer"
                 draggable="true"
                 @ondragstart="@(e => { e.DataTransfer.EffectAllowed = "move"; KescoDragState.DraggedColumn = "Порядок"; })"
                 @onclick="@(async () => { if (_dataGrid is not null) await _dataGrid.ToggleSort("Порядок"); })">
                <MudText Style="flex:1;text-align:center">Порядок</MudText>
                @if (_dataGrid is not null) { @_dataGrid.GetSortBadge("Порядок") }
            </div>
        </HeaderTemplate>
        <CellTemplate>
            @if (context.Item is DetailRow<MedicalTest> detail)
            {
                <MudText>@detail.Item.Order</MudText>
            }
        </CellTemplate>
    </TemplateColumn>

    <TemplateColumn T="IGridRow" Title="Группа">
        <CellTemplate>
            @if (context.Item is DetailRow<MedicalTest> detail)
            {
                <MudIcon Icon="@(detail.Item.IsGroup ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                         Color="@(detail.Item.IsGroup ? Color.Success : Color.Default)"
                         Size="Size.Small" />
            }
        </CellTemplate>
    </TemplateColumn>

    <TemplateColumn T="IGridRow" Title="Заключение">
        <CellTemplate>
            @if (context.Item is DetailRow<MedicalTest> detail)
            {
                <MudIcon Icon="@(detail.Item.IsConclusion ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                         Color="@(detail.Item.IsConclusion ? Color.Success : Color.Default)"
                         Size="Size.Small" />
            }
        </CellTemplate>
    </TemplateColumn>

</KescoGrid>

@code {
    // ── Ссылка на грид ──────────────────────────────────────────────────────────
    private KescoGrid<IGridRow> _dataGrid = null!;

    // ── Настройки источника данных ──────────────────────────────────────────────

    protected override string SelectSql => SQLQueries.SELECT_МедицинскиеАнализы;

    /// <summary>Поиск в плоском режиме по алиасам JOIN-запроса.</summary>
    protected override string[] FlatSearchColumns    => ["a.НазваниеАнализа", "t.ТипМедицинскогоАнализа"];

    /// <summary>Поиск в группированном режиме по выходным именам подзапроса.</summary>
    protected override string[] GroupedSearchColumns => ["НазваниеАнализа", "TestTypeName"];

    protected override string DefaultOrder => "Порядок, НазваниеАнализа";

    protected override Dictionary<string, string> GroupExprMap => _groupExprMap;

    protected override Dictionary<string, string>? FilterFlatColumnMap => _filterFlatColumnMap;

    // ── Конфигурация колонок ────────────────────────────────────────────────────

    /// <summary>Колонки доступные для группировки: отображаемое имя → SQL-имя.</summary>
    private static readonly Dictionary<string, string> _groupColumnsDef = new()
    {
        ["Тип"]      = "TestTypeName",
        ["Код"]      = "КодМедицинскогоАнализа",
        ["Название"] = "НазваниеАнализа",
        ["Порядок"]  = "Порядок",
    };

    /// <summary>
    /// Маппинг SQL-имён из GroupColumns на выходные имена подзапроса GROUP BY.
    /// </summary>
    private static readonly Dictionary<string, string> _groupExprMap = new()
    {
        ["TestTypeName"]           = "TestTypeName",
        ["КодМедицинскогоАнализа"] = "КодМедицинскогоАнализа",
        ["НазваниеАнализа"]        = "НазваниеАнализа",
        ["Порядок"]                = "Порядок",
    };

    /// <summary>Колонки доступные для фильтрации: отображаемое имя → SQL-имя.</summary>
    private static readonly Dictionary<string, string> _filterColumnsDef = new()
    {
        ["Код"]        = "КодМедицинскогоАнализа",
        ["Название"]   = "НазваниеАнализа",
        ["Тип"]        = "TestTypeName",
        ["Порядок"]    = "Порядок",
        ["Группа"]     = "Группа",
        ["Заключение"] = "Заключение",
    };

    /// <summary>Тип данных для каждой фильтруемой колонки: SQL-имя → ColumnType.</summary>
    private static readonly Dictionary<string, ColumnType> _filterColumnTypes = new()
    {
        ["КодМедицинскогоАнализа"] = ColumnType.Number,
        ["НазваниеАнализа"]        = ColumnType.Text,
        ["TestTypeName"]           = ColumnType.Text,
        ["Порядок"]                = ColumnType.Number,
        ["Группа"]                 = ColumnType.Boolean,
        ["Заключение"]             = ColumnType.Boolean,
    };

    /// <summary>
    /// Маппинг SQL-имён фильтра → алиасы таблиц для плоского WHERE.
    /// </summary>
    private static readonly Dictionary<string, string> _filterFlatColumnMap = new()
    {
        ["TestTypeName"]           = "t.ТипМедицинскогоАнализа",
        ["НазваниеАнализа"]        = "a.НазваниеАнализа",
        ["КодМедицинскогоАнализа"] = "a.КодМедицинскогоАнализа",
        ["Порядок"]                = "a.Порядок",
        ["Группа"]                 = "a.Группа",
        ["Заключение"]             = "a.Заключение",
    };

    // ── Обработка событий грида ─────────────────────────────────────────────────

    private Task OnQueryChanged(KescoDataQuery query) => OnQueryChangedBase(query);

    // ── Диалоги ─────────────────────────────────────────────────────────────────

    /// <summary>Открывает диалог добавления нового исследования.</summary>
    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters<MedicalTestEditDialog>
        {
            { x => x.Model, new MedicalTest() }
        };
        var options = new DialogOptionsEx { MaxWidth = MaxWidth.Small, FullWidth = true, DragMode = MudDialogDragMode.Simple };
        var dialog  = await DialogService.ShowExAsync<MedicalTestEditDialog>("Новое исследование", parameters, options);
        if (!(await dialog.Result)?.Canceled ?? false)
        {
            Snackbar.Add("Запись добавлена", Severity.Success);
            await LoadData();
        }
    }

    /// <summary>Обрабатывает клик по строке: раскрывает группу или открывает диалог редактирования.</summary>
    private async Task OnRowClicked(DataGridRowClickEventArgs<IGridRow> args)
    {
        if (args.Item is GroupHeaderRow header)
        {
            await ToggleGroup(header);
            return;
        }

        if (args.Item is DetailRow<MedicalTest> detail)
        {
            var parameters = new DialogParameters<MedicalTestEditDialog>
            {
                { x => x.Model, detail.Item }
            };
            var options = new DialogOptionsEx { MaxWidth = MaxWidth.Small, FullWidth = true, DragMode = MudDialogDragMode.Simple };
            var dialog  = await DialogService.ShowExAsync<MedicalTestEditDialog>("Редактирование", parameters, options);
            if (!(await dialog.Result)?.Canceled ?? false)
                Snackbar.Add("Запись обновлена", Severity.Success);
            await LoadData();
        }
    }
}
